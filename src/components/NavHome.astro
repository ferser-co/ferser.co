---
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';
import LangSwitcher from './LangSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';
import CurrencySwitcher from './CurrencySwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const homeHref = localizedPath(lang, '/');
const contactHref = localizedPath(lang, '/contacto');
---

<header class="fixed inset-x-0 top-0 z-50">
  <nav
    aria-label="Principal"
    class="border-b border-slate-200/60 bg-white/70 backdrop-blur-xl supports-[backdrop-filter]:bg-white/60 dark:border-slate-800/60 dark:bg-slate-950/70 dark:supports-[backdrop-filter]:bg-slate-950/60 transition-colors"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex h-16 items-center justify-between gap-3 sm:gap-4">
        <a
          href={homeHref}
          class="text-2xl sm:text-3xl font-black tracking-tight text-blue-700 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition-colors"
          aria-label="Ferser — Inicio"
        >
          Ferser
        </a>

        <span
          class="hidden xl:block flex-1 truncate px-6 text-center text-sm font-medium text-slate-500 dark:text-slate-400"
        >
          {t('nav.tagline')}
        </span>

        <div class="flex items-center gap-2 sm:gap-3">
          <CurrencySwitcher />
          <ThemeToggle />
          <LangSwitcher pathWithoutLang="/" />
          <a
            href={contactHref}
            class="inline-flex items-center rounded-full bg-blue-600 px-4 sm:px-5 py-2 text-sm sm:text-base font-semibold text-white shadow-md shadow-blue-500/20 hover:bg-blue-700 hover:shadow-lg hover:shadow-blue-500/30 dark:bg-blue-500 dark:hover:bg-blue-400 dark:shadow-blue-500/30 focus-visible:outline-2 focus-visible:outline-blue-600 transition-all"
          >
            {t('nav.contact')}
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>
