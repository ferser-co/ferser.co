---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

import Icon from './Icon.astro';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// FormSubmit: zero-config relay a contacto@ferser.co.
// El primer envío dispara un correo de activación; tras hacer click en el
// enlace, todos los siguientes mensajes llegan al inbox sin más setup.
const FORM_ENDPOINT = 'https://formsubmit.co/ajax/contacto@ferser.co';
const FORM_FALLBACK = 'https://formsubmit.co/contacto@ferser.co';
---

<div
  class="fade-in-up rounded-3xl border border-slate-100 dark:border-slate-700 bg-white/90 dark:bg-slate-900/70 p-6 sm:p-10 shadow-xl backdrop-blur-sm"
>
  <div class="mb-8">
    <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white">{t('form.title')}</h2>
    <p class="mt-2 text-slate-600 dark:text-slate-300">{t('form.subtitle')}</p>
  </div>

  <form
    id="contact-form"
    action={FORM_FALLBACK}
    method="POST"
    class="grid grid-cols-1 gap-5 sm:grid-cols-2"
    data-endpoint={FORM_ENDPOINT}
    data-lang={lang}
  >
    {/* Honeypot anti-spam (FormSubmit reconoce _honey) */}
    <input type="text" name="_honey" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
    {/* Desactiva el captcha por defecto de FormSubmit (usamos honeypot) */}
    <input type="hidden" name="_captcha" value="false" />
    <input type="hidden" name="_template" value="table" />

    <label class="block sm:col-span-1">
      <span class="mb-1.5 block text-sm font-semibold text-slate-700 dark:text-slate-200">{t('form.name.label')}</span>
      <input
        name="name"
        type="text"
        required
        autocomplete="name"
        placeholder={t('form.name.placeholder')}
        class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30 dark:border-slate-700 dark:bg-slate-800 dark:text-white dark:placeholder:text-slate-500 transition"
      />
    </label>

    <label class="block sm:col-span-1">
      <span class="mb-1.5 block text-sm font-semibold text-slate-700 dark:text-slate-200">{t('form.email.label')}</span>
      <input
        name="email"
        type="email"
        required
        autocomplete="email"
        placeholder={t('form.email.placeholder')}
        class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30 dark:border-slate-700 dark:bg-slate-800 dark:text-white dark:placeholder:text-slate-500 transition"
      />
    </label>

    <label class="block sm:col-span-2">
      <span class="mb-1.5 block text-sm font-semibold text-slate-700 dark:text-slate-200">{t('form.subject.label')}</span>
      <input
        name="user_subject"
        type="text"
        required
        placeholder={t('form.subject.placeholder')}
        class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30 dark:border-slate-700 dark:bg-slate-800 dark:text-white dark:placeholder:text-slate-500 transition"
      />
    </label>

    <label class="block sm:col-span-2">
      <span class="mb-1.5 block text-sm font-semibold text-slate-700 dark:text-slate-200">{t('form.message.label')}</span>
      <textarea
        name="message"
        required
        rows="5"
        placeholder={t('form.message.placeholder')}
        class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30 dark:border-slate-700 dark:bg-slate-800 dark:text-white dark:placeholder:text-slate-500 transition resize-y"
      ></textarea>
    </label>

    <div class="sm:col-span-2 flex items-center justify-between gap-4 flex-wrap">
      <p
        id="form-status"
        role="status"
        aria-live="polite"
        class="text-sm text-slate-500 dark:text-slate-400 flex-1 min-w-0"
      ></p>

      <button
        type="submit"
        class="inline-flex items-center gap-2 rounded-full bg-blue-600 px-6 py-3 text-base font-semibold text-white shadow-md shadow-blue-500/20 hover:bg-blue-700 hover:shadow-lg hover:shadow-blue-500/30 disabled:cursor-not-allowed disabled:bg-slate-300 disabled:text-slate-500 disabled:shadow-none dark:bg-blue-500 dark:hover:bg-blue-400 dark:disabled:bg-slate-700 dark:disabled:text-slate-400 focus-visible:outline-2 focus-visible:outline-blue-600 transition-all"
      >
        <span data-form-label-default>{t('form.send')}</span>
        <span data-form-label-loading class="hidden">{t('form.sending')}</span>
        <Icon name="send" class="w-4 h-4" />
      </button>
    </div>
  </form>
</div>

<script
  is:inline
  define:vars={{
    successTitle: t('form.success.title'),
    successDesc: t('form.success.desc'),
    errorTitle: t('form.error.title'),
    errorDesc: t('form.error.desc'),
  }}
>
  (function () {
    const form = document.getElementById('contact-form');
    if (!form) return;
    const status = document.getElementById('form-status');
    const submitBtn = form.querySelector('button[type="submit"]');
    const labelDefault = submitBtn?.querySelector('[data-form-label-default]');
    const labelLoading = submitBtn?.querySelector('[data-form-label-loading]');

    // Pre-llenar el asunto según ?plan=X
    try {
      const params = new URLSearchParams(window.location.search);
      const plan = params.get('plan');
      const planLabels = { esencial: 'Esencial', plus: 'Plus' };
      if (plan && planLabels[plan]) {
        const subjectField = form.querySelector('input[name="user_subject"]');
        const messageField = form.querySelector('textarea[name="message"]');
        if (subjectField && !subjectField.value) {
          subjectField.value = `Interés en plan ${planLabels[plan]} (oferta de lanzamiento)`;
        }
        if (messageField && !messageField.value) {
          messageField.value = `Hola, me interesa el plan ${planLabels[plan]} de la oferta de lanzamiento. Mi negocio es:\n\n`;
        }
      }

      // Pre-llenar el asunto según ?servicio=X (tarjetas de servicios)
      const servicio = params.get('servicio');
      const isEn = (form.dataset.lang || 'es') === 'en';
      const servicioLabels = isEn
        ? { consulting: 'IT Consulting', dev: 'Software Development', training: 'IT Training', automation: 'Automations' }
        : { consulting: 'Consultoría TI', dev: 'Desarrollo de Software', training: 'Capacitación Informática', automation: 'Automatizaciones' };
      if (servicio && servicioLabels[servicio]) {
        const label = servicioLabels[servicio];
        const subjectField = form.querySelector('input[name="user_subject"]');
        const messageField = form.querySelector('textarea[name="message"]');
        if (subjectField && !subjectField.value) {
          subjectField.value = isEn ? `Interest in ${label}` : `Interés en ${label}`;
        }
        if (messageField && !messageField.value) {
          messageField.value = isEn
            ? `Hi, I'm interested in your ${label} service. My business is:\n\n`
            : `Hola, me interesa su servicio de ${label}. Mi negocio es:\n\n`;
        }
      }
    } catch (_) {}

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Honeypot check: si está lleno es un bot
      if (form.querySelector('input[name="_honey"]')?.value) return;

      // No permitir el envío si falta el correo (u otro campo requerido) o el
      // formato del correo es inválido. reportValidity() muestra el aviso nativo.
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      submitBtn.disabled = true;
      labelDefault?.classList.add('hidden');
      labelLoading?.classList.remove('hidden');
      status.textContent = '';
      status.className = 'text-sm text-slate-500 dark:text-slate-400 flex-1 min-w-0';

      const fd = new FormData(form);
      const userSubject = fd.get('user_subject') || 'Nuevo mensaje';
      const senderName = fd.get('name') || 'Anónimo';
      fd.set('_subject', `[ferser.co] ${userSubject} — ${senderName}`);
      fd.delete('user_subject');
      fd.set('_replyto', fd.get('email'));

      try {
        const res = await fetch(form.dataset.endpoint, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: fd,
        });
        const json = await res.json().catch(() => ({}));
        const ok = res.ok && (json.success === 'true' || json.success === true);
        if (ok) {
          status.innerHTML = `<strong class="text-green-600 dark:text-green-400">${successTitle}</strong> · ${successDesc}`;
          status.className = 'text-sm flex-1 min-w-0';
          form.reset();
        } else {
          throw new Error(json.message || 'request failed');
        }
      } catch (err) {
        status.innerHTML = `<strong class="text-red-600 dark:text-red-400">${errorTitle}</strong> · ${errorDesc}`;
        status.className = 'text-sm flex-1 min-w-0';
      } finally {
        submitBtn.disabled = false;
        labelDefault?.classList.remove('hidden');
        labelLoading?.classList.add('hidden');
      }
    });
  })();
</script>
