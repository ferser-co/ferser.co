---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import type { TranslationKey } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const sections: Array<{ titleKey: TranslationKey; bodyKey: TranslationKey }> = [
  { titleKey: 'privacy.intro.title', bodyKey: 'privacy.intro.body' },
  { titleKey: 'privacy.data.title', bodyKey: 'privacy.data.body' },
  { titleKey: 'privacy.use.title', bodyKey: 'privacy.use.body' },
  { titleKey: 'privacy.thirdparty.title', bodyKey: 'privacy.thirdparty.body' },
  { titleKey: 'privacy.retention.title', bodyKey: 'privacy.retention.body' },
  { titleKey: 'privacy.rights.title', bodyKey: 'privacy.rights.body' },
  { titleKey: 'privacy.changes.title', bodyKey: 'privacy.changes.body' },
  { titleKey: 'privacy.contact.title', bodyKey: 'privacy.contact.body' },
];
---

<section class="relative min-h-screen pt-32 pb-20 overflow-hidden">
  <div class="blob bg-blue-300 dark:bg-blue-700 w-80 h-80 rounded-full top-40 right-[-100px] opacity-25"></div>

  <article class="max-w-3xl mx-auto px-6 relative z-10">
    <header class="mb-12 fade-in-up">
      <h1 class="text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white mb-3">
        {t('privacy.h1')}
      </h1>
      <p class="text-sm text-slate-500 dark:text-slate-400">{t('privacy.updated')}</p>
    </header>

    <div class="space-y-10">
      {sections.map(({ titleKey, bodyKey }) => (
        <section class="fade-in-up">
          <h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white mb-3">{t(titleKey)}</h2>
          <p class="text-base sm:text-lg leading-relaxed text-slate-700 dark:text-slate-300">{t(bodyKey)}</p>
        </section>
      ))}
    </div>
  </article>
</section>
