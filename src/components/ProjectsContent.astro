---
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';
import HostalkChatPreview from './HostalkChatPreview.astro';

import Icon from './Icon.astro';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const detailHref = localizedPath(lang, '/proyectos/hostalk');

const techStack = [
  'React + Vite',
  'FastAPI async',
  'WebSockets',
  'PostgreSQL',
  'Docker + Caddy',
  'Web Speech API',
];

const forzecHref = 'https://forzec.com';
const forzecTech = ['Astro', 'Tailwind CSS', 'SSG', 'Landing'];
---

<section class="relative pt-32 pb-16 overflow-hidden">
  <div class="blob bg-blue-300 dark:bg-blue-700 w-96 h-96 rounded-full top-20 left-[-100px] opacity-30"></div>
  <div class="blob bg-cyan-300 dark:bg-cyan-700 w-80 h-80 rounded-full top-10 right-[-50px] animation-delay-2000 opacity-30"></div>

  <div class="max-w-6xl mx-auto px-6 text-center relative z-10 fade-in-up">
    <h1 class="text-5xl md:text-6xl font-black tracking-tighter text-slate-900 dark:text-white mb-6">
      {t('projects.h1.line1')}
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-cyan-500 to-blue-500 dark:from-blue-400 dark:via-cyan-300 dark:to-blue-300">
        {t('projects.h1.line2')}
      </span>
    </h1>
    <p class="text-lg md:text-xl text-slate-600 dark:text-slate-300 leading-relaxed font-medium max-w-2xl mx-auto">
      {t('projects.subtitle')}
    </p>
  </div>
</section>

<section class="pb-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-center gap-3 mb-8 fade-in-up">
      <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800"></div>
      <span class="text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">
        {t('projects.featured')}
      </span>
      <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800"></div>
    </div>

    <article class="fade-in-up relative overflow-hidden rounded-3xl border border-slate-100 dark:border-slate-700 bg-white dark:bg-slate-900 shadow-2xl">
      <div class="absolute -inset-px rounded-3xl bg-gradient-to-r from-blue-500/20 via-cyan-400/20 to-blue-500/20 blur-2xl opacity-40 -z-10"></div>

      <div class="grid lg:grid-cols-5 gap-0">
        <div class="lg:col-span-3 p-8 sm:p-12">
          <div class="flex items-center gap-3 mb-5">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-100 dark:bg-amber-900/40 px-3 py-1 text-xs font-bold uppercase tracking-wide text-amber-700 dark:text-amber-300">
              <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span>
              {t('projects.status.development')}
            </span>
          </div>

          <h2 class="text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white mb-3">
            {t('projects.hostalk.title')}
          </h2>
          <p class="text-lg text-blue-700 dark:text-blue-400 font-semibold mb-6">
            {t('projects.hostalk.tagline')}
          </p>

          <p class="text-base sm:text-lg text-slate-600 dark:text-slate-300 leading-relaxed mb-8">
            {t('projects.hostalk.description')}
          </p>

          <div class="flex flex-wrap gap-2 mb-8">
            {techStack.map((tech) => (
              <span class="inline-flex items-center rounded-md border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-2.5 py-1 text-xs font-semibold text-slate-700 dark:text-slate-300">
                {tech}
              </span>
            ))}
          </div>

          <div class="flex flex-wrap gap-3">
            <a
              href={detailHref}
              class="inline-flex items-center gap-2 rounded-full bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white shadow-md shadow-blue-500/20 hover:bg-blue-700 hover:shadow-lg hover:shadow-blue-500/30 dark:bg-blue-500 dark:hover:bg-blue-400 transition-all"
            >
              {t('projects.hostalk.cta.detail')}
              <Icon name="arrow-right" class="w-4 h-4" />
            </a>
            <a
              href="https://hostalk.ferser.co"
              class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700 transition-all"
            >
              {t('projects.hostalk.cta.app')}
              <Icon name="arrow-up-right" class="w-4 h-4" />
            </a>
          </div>
        </div>

        <div class="lg:col-span-2 p-6 sm:p-8 lg:p-10 flex items-center border-t lg:border-t-0 lg:border-l border-slate-100 dark:border-slate-700">
          <HostalkChatPreview />
        </div>
      </div>
    </article>

    {/* Divisor — entregados */}
    <div class="flex items-center gap-3 mt-20 mb-8 fade-in-up">
      <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800"></div>
      <span class="text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">
        {t('projects.delivered')}
      </span>
      <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800"></div>
    </div>

    {/* Forzec — proyecto entregado */}
    <article class="fade-in-up relative overflow-hidden rounded-3xl border border-slate-100 dark:border-slate-700 bg-white dark:bg-slate-900 shadow-2xl">
      <div class="absolute -inset-px rounded-3xl bg-gradient-to-r from-amber-500/20 via-orange-400/20 to-amber-500/20 blur-2xl opacity-40 -z-10"></div>

      <div class="grid lg:grid-cols-5 gap-0">
        <div class="lg:col-span-3 p-8 sm:p-12">
          <div class="flex items-center gap-3 mb-5">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-100 dark:bg-emerald-900/40 px-3 py-1 text-xs font-bold uppercase tracking-wide text-emerald-700 dark:text-emerald-300">
              <Icon name="rocket" class="w-3 h-3" />
              {t('projects.status.launched')}
            </span>
          </div>

          <h2 class="text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white mb-3">
            {t('projects.forzec.title')}
          </h2>
          <p class="text-lg text-amber-700 dark:text-amber-400 font-semibold mb-6">
            {t('projects.forzec.tagline')}
          </p>

          <p class="text-base sm:text-lg text-slate-600 dark:text-slate-300 leading-relaxed mb-8">
            {t('projects.forzec.description')}
          </p>

          <div class="flex flex-wrap gap-2 mb-8">
            {forzecTech.map((tech) => (
              <span class="inline-flex items-center rounded-md border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-2.5 py-1 text-xs font-semibold text-slate-700 dark:text-slate-300">
                {tech}
              </span>
            ))}
          </div>

          <div class="flex flex-wrap gap-3">
            <a
              href={forzecHref}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 rounded-full bg-gradient-to-br from-amber-500 to-orange-600 px-5 py-2.5 text-sm font-semibold text-white shadow-md shadow-orange-500/20 hover:shadow-lg hover:shadow-orange-500/30 hover:-translate-y-0.5 transition-all"
            >
              {t('projects.forzec.cta')}
              <Icon name="arrow-up-right" class="w-4 h-4" />
            </a>
          </div>
        </div>

        <div class="lg:col-span-2 relative flex items-center justify-center p-6 sm:p-8 lg:p-10 border-t lg:border-t-0 lg:border-l border-slate-100 dark:border-slate-700 bg-gradient-to-br from-amber-500 to-orange-600 overflow-hidden">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.25),transparent)]"></div>
          <div class="relative text-center">
            <Icon name="spray-can" class="w-16 h-16 mx-auto text-white/90 mb-3" />
            <span class="block text-4xl font-black tracking-tighter text-white">Forzec</span>
            <span class="block text-sm font-semibold text-white/80 mt-1">forzec.com</span>
          </div>
        </div>
      </div>
    </article>

    <div class="mt-16 fade-in-up rounded-3xl border border-slate-200 dark:border-slate-700 bg-gradient-to-br from-slate-50 to-white dark:from-slate-900 dark:to-slate-950 p-8 sm:p-12 text-center">
      <div class="inline-flex w-12 h-12 items-center justify-center rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 mb-4">
        <Icon name="github" class="w-6 h-6" />
      </div>
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-3">{t('projects.more.title')}</h2>
      <p class="text-slate-600 dark:text-slate-300 mb-6 max-w-xl mx-auto">{t('projects.more.subtitle')}</p>
      <a
        href="https://github.com/orgs/ferser-co/repositories"
        class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:border-slate-400 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 dark:hover:bg-slate-700 transition-all"
      >
        {t('projects.more.cta')}
        <Icon name="arrow-up-right" class="w-4 h-4" />
      </a>
    </div>
  </div>
</section>
