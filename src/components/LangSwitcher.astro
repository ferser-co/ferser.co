---
import { getLangFromUrl, alternateLangPath } from '../i18n/utils';

import Icon from './Icon.astro';
interface Props {
  pathWithoutLang: string;
}

const { pathWithoutLang } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const alt = alternateLangPath(lang, pathWithoutLang);
const labels = { es: 'ES', en: 'EN' } as const;
const fullNames = { es: 'Español', en: 'English' } as const;
---

<a
  href={alt.href}
  hreflang={alt.lang}
  aria-label={`Cambiar idioma a ${fullNames[alt.lang]}`}
  class="inline-flex items-center gap-1.5 rounded-full border border-slate-200/70 bg-white/60 px-3 py-1.5 text-xs sm:text-sm font-semibold text-slate-700 hover:bg-white hover:border-slate-300 hover:text-slate-900 dark:border-slate-700 dark:bg-slate-800/70 dark:text-slate-300 dark:hover:bg-slate-700 dark:hover:text-white dark:hover:border-slate-600 focus-visible:outline-2 focus-visible:outline-blue-600 transition-colors"
>
  <Icon name="languages" class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-slate-500 dark:text-slate-400" />
  <span>{labels[alt.lang]}</span>
</a>
