---
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';

import Icon from './Icon.astro';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const projectsHref = localizedPath(lang, '/proyectos');
const privacyHref = localizedPath(lang, '/privacidad');
---

<footer class="py-12 border-t border-slate-200 dark:border-slate-800 bg-white/40 dark:bg-slate-950/40">
  <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="text-center md:text-left">
      <span class="font-bold text-xl text-slate-800 dark:text-slate-100">Ferser</span>
      <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">{t('footer.copyright')}</p>
    </div>

    <div class="flex items-center gap-5 sm:gap-6">
      <a
        href={projectsHref}
        class="text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
      >
        {t('footer.projects')}
      </a>
      <a
        href={privacyHref}
        class="text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
      >
        {t('footer.privacy')}
      </a>
      <span class="hidden sm:inline w-px h-4 bg-slate-200 dark:bg-slate-700"></span>
      <a
        href="https://www.linkedin.com/in/zebastian-fernandez-05705b168/?locale=es"
        class="text-slate-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
        aria-label="LinkedIn"
      >
        <Icon name="linkedin" class="w-5 h-5" />
      </a>
      <a
        href="https://github.com/orgs/ferser-co/repositories"
        class="text-slate-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
        aria-label="GitHub"
      >
        <Icon name="github" class="w-5 h-5" />
      </a>
    </div>
  </div>
</footer>
