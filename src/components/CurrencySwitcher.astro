---
import Icon from './Icon.astro';
---

<div class="relative inline-block" data-currency-dropdown>
  <button
    type="button"
    data-currency-trigger
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-label="Cambiar moneda / Change currency"
    class="inline-flex items-center gap-1.5 rounded-full border border-slate-200/70 bg-white/60 px-3 py-1.5 text-xs sm:text-sm font-semibold text-slate-700 hover:bg-white hover:border-slate-300 hover:text-slate-900 dark:border-slate-700 dark:bg-slate-800/70 dark:text-slate-300 dark:hover:bg-slate-700 dark:hover:text-white dark:hover:border-slate-600 focus-visible:outline-2 focus-visible:outline-blue-600 transition-colors"
  >
    <Icon name="circle-dollar-sign" class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-slate-500 dark:text-slate-400" />
    <span class="cur cur-cop">COP</span>
    <span class="cur cur-usd">USD</span>
    <span class="cur cur-eur">EUR</span>
    <Icon name="chevron-down" class="w-3 h-3 text-slate-400 dark:text-slate-500" />
  </button>

  <div
    data-currency-menu
    role="listbox"
    aria-label="Moneda"
    class="hidden absolute right-0 top-full mt-2 min-w-[12rem] rounded-xl border border-slate-200 bg-white p-1.5 shadow-xl dark:border-slate-700 dark:bg-slate-900 z-50"
  >
    <button type="button" role="option" data-currency-pick="COP" class="w-full text-left px-3 py-2 rounded-lg text-sm hover:bg-slate-100 dark:hover:bg-slate-800 flex items-center justify-between gap-3 transition-colors">
      <span class="flex items-baseline gap-2">
        <span class="font-bold text-slate-900 dark:text-white">COP</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">Peso colombiano</span>
      </span>
      <Icon name="check" class="cur cur-cop w-4 h-4 text-emerald-600 dark:text-emerald-400" />
    </button>
    <button type="button" role="option" data-currency-pick="USD" class="w-full text-left px-3 py-2 rounded-lg text-sm hover:bg-slate-100 dark:hover:bg-slate-800 flex items-center justify-between gap-3 transition-colors">
      <span class="flex items-baseline gap-2">
        <span class="font-bold text-slate-900 dark:text-white">USD</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">US Dollar</span>
      </span>
      <Icon name="check" class="cur cur-usd w-4 h-4 text-emerald-600 dark:text-emerald-400" />
    </button>
    <button type="button" role="option" data-currency-pick="EUR" class="w-full text-left px-3 py-2 rounded-lg text-sm hover:bg-slate-100 dark:hover:bg-slate-800 flex items-center justify-between gap-3 transition-colors">
      <span class="flex items-baseline gap-2">
        <span class="font-bold text-slate-900 dark:text-white">EUR</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">Euro</span>
      </span>
      <Icon name="check" class="cur cur-eur w-4 h-4 text-emerald-600 dark:text-emerald-400" />
    </button>
  </div>
</div>
