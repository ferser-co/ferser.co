---
import { getLangFromUrl, localizedPath } from '../i18n/utils';
import Price from './Price.astro';
import CurrencyCode from './CurrencyCode.astro';
import Icon from './Icon.astro';

const lang = getLangFromUrl(Astro.url);

const contactBase = localizedPath(lang, '/contacto');
const ofertaHref = localizedPath(lang, '/oferta-de-lanzamiento');

const t = lang === 'es' ? {
  eyebrow: 'Oferta de lanzamiento',
  title: 'Tu sitio web profesional, listo en una semana',
  subtitle: 'Sitio + dominio + hosting incluidos por un año. Tres plantillas a elegir, listas para personalizar.',
  esencialName: 'Esencial',
  esencialDesc: 'Para tener presencia profesional online.',
  esencialPeriod: ' / año',
  esencialFeatures: [
    'Landing pro con 5–6 secciones',
    'Hosting + dominio por 1 año',
    'SSL y optimización para móvil',
    'SEO básico configurado',
  ],
  esencialCta: 'Quiero el Esencial',
  plusName: 'Plus',
  plusDesc: 'Con captura de leads desde el primer día.',
  plusPeriod: ' / año',
  recommended: 'Recomendado',
  plusFeatures: [
    'Todo lo del plan Esencial',
    'Formulario de contacto',
    'Panel privado para ver mensajes',
    'Notificaciones por correo',
  ],
  plusCta: 'Quiero el Plus',
  vigencia: 'Vigencia: hasta el 15 de agosto de 2026',
  ctaSecondary: 'Ver detalles de la oferta',
} : {
  eyebrow: 'Launch offer',
  title: 'Your professional website, live in one week',
  subtitle: 'Website + domain + hosting included for one year. Three templates to choose from, ready to customize.',
  esencialName: 'Essential',
  esencialDesc: 'For a professional online presence.',
  esencialPeriod: ' / year',
  esencialFeatures: [
    'Pro landing with 5–6 sections',
    'Hosting + domain for 1 year',
    'SSL and mobile optimization',
    'Basic SEO configured',
  ],
  esencialCta: 'Get Essential',
  plusName: 'Plus',
  plusDesc: 'Capture leads from day one.',
  plusPeriod: ' / year',
  recommended: 'Recommended',
  plusFeatures: [
    'Everything in Essential',
    'Built-in contact form',
    'Private inbox to read messages',
    'Email notifications',
  ],
  plusCta: 'Get Plus',
  vigencia: 'Valid through August 15, 2026',
  ctaSecondary: 'See full offer details',
};

const esencialPrices = { cop: '$500.000', usd: '$145', eur: '€135' };
const plusPrices = { cop: '$700.000', usd: '$205', eur: '€185' };
---

<section id="oferta" class="py-20 sm:py-24 bg-gradient-to-b from-slate-50 to-white dark:from-slate-900 dark:to-slate-950">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-12 fade-in-up">
      <span class="inline-flex items-center gap-1.5 rounded-full bg-indigo-100 dark:bg-indigo-900/40 px-3 py-1 text-xs font-bold uppercase tracking-wider text-indigo-700 dark:text-indigo-300">
        <span class="relative flex h-1.5 w-1.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-indigo-400 opacity-75"></span>
          <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-indigo-600"></span>
        </span>
        {t.eyebrow}
      </span>
      <h2 class="mt-4 text-3xl sm:text-4xl lg:text-5xl font-black tracking-tighter text-slate-900 dark:text-white mb-3">
        {t.title}
      </h2>
      <p class="text-base sm:text-lg text-slate-600 dark:text-slate-300 max-w-2xl mx-auto">
        {t.subtitle}
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-5 max-w-4xl mx-auto fade-in-up">
      {/* Esencial */}
      <article class="rounded-3xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 p-7 sm:p-8 shadow-sm">
        <h3 class="text-lg font-bold text-slate-900 dark:text-white">{t.esencialName}</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">{t.esencialDesc}</p>
        <div class="mt-5 mb-6">
          <Price class="text-4xl font-black tracking-tight text-slate-900 dark:text-white" {...esencialPrices} />
          <span class="text-base text-slate-500 dark:text-slate-400 ml-1.5"><CurrencyCode />{t.esencialPeriod}</span>
        </div>
        <ul class="space-y-2.5 mb-7">
          {t.esencialFeatures.map((f) => (
            <li class="flex items-start gap-2.5 text-sm text-slate-700 dark:text-slate-300">
              <Icon name="check" class="w-4 h-4 mt-0.5 shrink-0 text-emerald-600 dark:text-emerald-400" />
              {f}
            </li>
          ))}
        </ul>
        <a
          href={`${contactBase}?plan=esencial`}
          class="block w-full text-center rounded-lg bg-slate-900 dark:bg-slate-100 text-white dark:text-slate-900 px-6 py-3 text-sm font-bold hover:bg-slate-800 dark:hover:bg-white transition-colors"
        >
          {t.esencialCta}
        </a>
      </article>

      {/* Plus */}
      <article class="relative rounded-3xl border-2 border-indigo-600 bg-gradient-to-br from-indigo-50/60 to-white dark:from-indigo-950/30 dark:to-slate-900 p-7 sm:p-8 shadow-xl shadow-indigo-500/10 ring-1 ring-indigo-600/10">
        <span class="absolute -top-3 left-7 inline-flex items-center gap-1 rounded-full bg-gradient-to-br from-indigo-600 to-violet-600 px-3 py-1 text-xs font-bold text-white shadow-md">
          <Icon name="sparkles" class="w-3 h-3" />
          {t.recommended}
        </span>
        <h3 class="text-lg font-bold text-slate-900 dark:text-white">{t.plusName}</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">{t.plusDesc}</p>
        <div class="mt-5 mb-6">
          <Price class="text-4xl font-black tracking-tight text-slate-900 dark:text-white" {...plusPrices} />
          <span class="text-base text-slate-500 dark:text-slate-400 ml-1.5"><CurrencyCode />{t.plusPeriod}</span>
        </div>
        <ul class="space-y-2.5 mb-7">
          {t.plusFeatures.map((f) => (
            <li class="flex items-start gap-2.5 text-sm text-slate-700 dark:text-slate-300">
              <Icon name="check" class="w-4 h-4 mt-0.5 shrink-0 text-indigo-600 dark:text-indigo-400" />
              {f}
            </li>
          ))}
        </ul>
        <a
          href={`${contactBase}?plan=plus`}
          class="block w-full text-center rounded-lg bg-gradient-to-br from-indigo-600 to-violet-600 text-white px-6 py-3 text-sm font-bold shadow-md shadow-indigo-500/25 hover:shadow-lg hover:shadow-indigo-500/40 hover:-translate-y-0.5 transition-all"
        >
          {t.plusCta}
        </a>
      </article>
    </div>

    <div class="mt-10 text-center flex flex-col sm:flex-row gap-x-6 gap-y-2 items-center justify-center fade-in-up">
      <span class="text-sm text-slate-500 dark:text-slate-400 inline-flex items-center gap-1.5">
        <Icon name="clock" class="w-4 h-4" />
        {t.vigencia}
      </span>
      <span class="hidden sm:inline text-slate-300 dark:text-slate-700">·</span>
      <a
        href={ofertaHref}
        class="text-sm font-semibold text-indigo-700 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 inline-flex items-center gap-1"
      >
        {t.ctaSecondary}
        <Icon name="arrow-right" class="w-3.5 h-3.5" />
      </a>
    </div>
  </div>
</section>
