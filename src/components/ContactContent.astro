---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ContactForm from './ContactForm.astro';

import Icon from './Icon.astro';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative min-h-screen pt-32 pb-20 overflow-hidden">
  <div class="blob bg-purple-300 dark:bg-purple-700 w-96 h-96 rounded-full top-20 right-[-100px] opacity-30"></div>
  <div class="blob bg-blue-400 dark:bg-blue-700 w-80 h-80 rounded-full bottom-20 left-[-50px] animation-delay-2000 opacity-30"></div>

  <div class="max-w-7xl w-full mx-auto px-6 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16 fade-in-up">
      <h1 class="text-5xl md:text-6xl font-black tracking-tighter text-slate-900 dark:text-white mb-6">
        {t('contact.hero.title1')}
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-500 dark:from-blue-400 dark:to-cyan-300">
          {t('contact.hero.title2')}
        </span>
      </h1>
      <p class="text-xl text-slate-600 dark:text-slate-300 leading-relaxed font-medium">
        {t('contact.hero.subtitle')}
      </p>
    </div>

    <div class="grid lg:grid-cols-[1.65fr_1fr] gap-8 lg:gap-10 items-start">
      {/* Form (primary action) */}
      <ContactForm />

      {/* Channels (supporting context) */}
      <aside class="fade-in-up" style="transition-delay: 0.1s;">
        <h2 class="mb-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">
          {t('contact.channels.title')}
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-1 gap-4">
          <a
            href="mailto:contacto@ferser.co"
            class="group flex items-start gap-4 rounded-2xl border border-slate-100 dark:border-slate-700 bg-white/80 dark:bg-slate-900/70 backdrop-blur-sm p-5 shadow-sm hover:shadow-lg hover:shadow-blue-500/10 hover:-translate-y-0.5 hover:border-blue-200 dark:hover:border-blue-800 transition-all"
          >
            <div class="shrink-0 w-11 h-11 rounded-xl bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-300 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Icon name="mail" class="w-5 h-5" />
            </div>
            <div class="min-w-0 flex-1">
              <h3 class="text-base font-bold text-slate-900 dark:text-white">{t('contact.email.title')}</h3>
              <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">{t('contact.email.desc')}</p>
              <p class="mt-2 text-sm font-semibold text-blue-600 dark:text-blue-400 truncate">contacto@ferser.co</p>
            </div>
          </a>

          <a
            href="https://wa.me/573228756421"
            class="group flex items-start gap-4 rounded-2xl border border-slate-100 dark:border-slate-700 bg-white/80 dark:bg-slate-900/70 backdrop-blur-sm p-5 shadow-sm hover:shadow-lg hover:shadow-green-500/10 hover:-translate-y-0.5 hover:border-green-200 dark:hover:border-green-800 transition-all"
          >
            <div class="shrink-0 w-11 h-11 rounded-xl bg-green-100 dark:bg-green-900/40 text-green-600 dark:text-green-300 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Icon name="message-circle" class="w-5 h-5" />
            </div>
            <div class="min-w-0 flex-1">
              <h3 class="text-base font-bold text-slate-900 dark:text-white">{t('contact.chat.title')}</h3>
              <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">{t('contact.chat.desc')}</p>
              <p class="mt-2 text-sm font-semibold text-slate-800 dark:text-slate-100">+57 322 875 6421</p>
            </div>
          </a>

          <div
            class="flex items-start gap-4 rounded-2xl border border-slate-100 dark:border-slate-700 bg-white/80 dark:bg-slate-900/70 backdrop-blur-sm p-5 shadow-sm"
          >
            <div class="shrink-0 w-11 h-11 rounded-xl bg-orange-100 dark:bg-orange-900/40 text-orange-600 dark:text-orange-300 flex items-center justify-center">
              <Icon name="clock" class="w-5 h-5" />
            </div>
            <div class="min-w-0 flex-1">
              <h3 class="text-base font-bold text-slate-900 dark:text-white">{t('contact.global.title')}</h3>
              <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">{t('contact.global.desc')}</p>
              <div class="mt-2 inline-flex items-center gap-2 text-xs font-semibold text-slate-700 dark:text-slate-200">
                <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                {t('contact.global.status')}
              </div>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>
