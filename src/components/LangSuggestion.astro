---
/**
 * Banner discreto y descartable que sugiere ver el sitio en el idioma del
 * visitante. NO redirige: las URLs por idioma + hreflang siguen siendo la
 * fuente de verdad para SEO. La lógica de cuándo mostrarlo vive en
 * src/scripts/geo.ts (decide según navigator.language y la IP del visitante).
 */
import { getLangFromUrl, alternateLangPath } from '../i18n/utils';
import Icon from './Icon.astro';

interface Props {
  pathWithoutLang: string;
}

const { pathWithoutLang } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const alt = alternateLangPath(lang, pathWithoutLang);

// Textos en el idioma de DESTINO (el que ofrece el banner).
const copy = {
  es: { message: 'Este sitio también está disponible en español.', action: 'Ver en español', dismiss: 'Cerrar' },
  en: { message: 'This site is also available in English.', action: 'View in English', dismiss: 'Dismiss' },
}[alt.lang];
---

<div
  data-lang-suggest
  data-suggest-lang={alt.lang}
  class="invisible opacity-0 translate-y-3 transition duration-300 ease-out fixed inset-x-0 bottom-4 z-50 mx-auto flex w-[calc(100%-2rem)] max-w-md items-center gap-3 rounded-2xl border border-slate-200/80 bg-white/90 px-4 py-3 shadow-2xl shadow-slate-900/10 backdrop-blur dark:border-slate-700/80 dark:bg-slate-900/90"
  role="region"
  aria-label={copy.message}
>
  <span class="shrink-0 inline-flex h-9 w-9 items-center justify-center rounded-xl bg-blue-50 text-blue-600 dark:bg-blue-950/50 dark:text-blue-400">
    <Icon name="languages" class="w-4 h-4" />
  </span>

  <p class="min-w-0 flex-1 text-sm font-medium text-slate-700 dark:text-slate-200">
    {copy.message}
  </p>

  <a
    href={alt.href}
    hreflang={alt.lang}
    class="shrink-0 inline-flex items-center gap-1.5 rounded-full bg-blue-600 px-3.5 py-1.5 text-xs font-semibold text-white hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-400 transition-colors"
  >
    {copy.action}
    <Icon name="arrow-right" class="w-3.5 h-3.5" />
  </a>

  <button
    type="button"
    data-lang-dismiss
    aria-label={copy.dismiss}
    class="shrink-0 inline-flex h-7 w-7 items-center justify-center rounded-full text-slate-400 hover:bg-slate-100 hover:text-slate-600 dark:hover:bg-slate-800 dark:hover:text-slate-200 transition-colors"
  >
    <Icon name="x" class="w-4 h-4" />
  </button>
</div>
