---
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const projectsHref = localizedPath(lang, '/proyectos');
const privacyHref = localizedPath(lang, '/privacidad');
---

<footer class="py-8 border-t border-slate-200 dark:border-slate-800 bg-white/40 dark:bg-slate-950/40 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-6 flex flex-col sm:flex-row justify-center items-center gap-3 sm:gap-5">
    <p class="text-sm text-slate-500 dark:text-slate-400">{t('footer.contact_copy')}</p>
    <span class="hidden sm:inline text-slate-300 dark:text-slate-700">·</span>
    <a
      href={projectsHref}
      class="text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
    >
      {t('footer.projects')}
    </a>
    <span class="hidden sm:inline text-slate-300 dark:text-slate-700">·</span>
    <a
      href={privacyHref}
      class="text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
    >
      {t('footer.privacy')}
    </a>
  </div>
</footer>
