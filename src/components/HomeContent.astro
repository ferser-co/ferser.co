---
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';
import type { TranslationKey } from '../i18n/ui';

import Icon from './Icon.astro';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const contactBase = localizedPath(lang, '/contacto');

// Tarjetas de servicio: cada una enlaza al contacto con el servicio
// preseleccionado (?servicio=…) y tiene su propio acento de color.
const services: Array<{
  key: string;
  icon: string;
  title: TranslationKey;
  desc: TranslationKey;
  iconWrap: string;
  bar: string;
  cta: string;
}> = [
  {
    key: 'consulting',
    icon: 'headset',
    title: 'services.consulting.title',
    desc: 'services.consulting.desc',
    iconWrap: 'bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-300',
    bar: 'from-blue-500 to-cyan-500',
    cta: 'text-blue-600 dark:text-blue-400',
  },
  {
    key: 'dev',
    icon: 'code',
    title: 'services.dev.title',
    desc: 'services.dev.desc',
    iconWrap: 'bg-purple-100 dark:bg-purple-900/40 text-purple-600 dark:text-purple-300',
    bar: 'from-purple-500 to-fuchsia-500',
    cta: 'text-purple-600 dark:text-purple-400',
  },
  {
    key: 'training',
    icon: 'book-open',
    title: 'services.training.title',
    desc: 'services.training.desc',
    iconWrap: 'bg-cyan-100 dark:bg-cyan-900/40 text-cyan-600 dark:text-cyan-300',
    bar: 'from-cyan-500 to-sky-500',
    cta: 'text-cyan-600 dark:text-cyan-400',
  },
  {
    key: 'automation',
    icon: 'workflow',
    title: 'services.automation.title',
    desc: 'services.automation.desc',
    iconWrap: 'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-600 dark:text-emerald-300',
    bar: 'from-emerald-500 to-teal-500',
    cta: 'text-emerald-600 dark:text-emerald-400',
  },
];
---

<section class="relative min-h-screen pt-32 pb-20 flex items-center justify-center overflow-hidden">
  <div class="blob bg-blue-300 dark:bg-blue-600 w-96 h-96 rounded-full top-1/4 left-10"></div>
  <div class="blob bg-purple-300 dark:bg-purple-700 w-80 h-80 rounded-full bottom-1/4 right-10 animation-delay-2000"></div>

  <div class="max-w-8xl mx-auto px-6 grid lg:grid-cols-2 gap-[10rem] items-center relative z-10">
    <div class="blob bg-blue-400/20 dark:bg-blue-500/15 w-[600px] h-[600px] rounded-full top-[-10%] left-[-10%] blur-[120px] animate-pulse"></div>
    <div class="blob bg-cyan-300/20 dark:bg-cyan-500/15 w-[500px] h-[500px] rounded-full bottom-[-10%] right-[-10%] blur-[100px]"></div>

    <div class="relative lg:-mr-10 z-10 max-w-7xl mx-auto px-auto flex flex-col items-center text-center">
      <div class="space-y-10 flex flex-col items-start">
        <h1 class="text-6xl md:text-7xl font-black leading-[1.05] tracking-tighter text-slate-900 dark:text-white max-w-5xl">
          {t('hero.title.line1')}<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-cyan-500 to-blue-500 dark:from-blue-400 dark:via-cyan-300 dark:to-blue-300">
            {t('hero.title.line2')}
          </span>
        </h1>

        <p class="text-xl md:text-2xl text-slate-600 dark:text-slate-300 leading-relaxed max-w-2xl mx-auto font-medium">
          {t('hero.description')}
        </p>

        <div class="flex flex-col sm:flex-row gap-5 w-full justify-center pt-4">
          <a
            href={`${localizedPath(lang, '/')}#servicios`}
            class="group flex items-center justify-center gap-3 bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-400 text-white px-10 py-5 rounded-2xl text-xl font-bold shadow-[0_20px_50px_-15px_rgba(37,99,235,0.4)] hover:-translate-y-1.5 transition-all duration-300"
          >
            {t('hero.cta.services')}
            <Icon name="arrow-down" class="w-6 h-6 group-hover:translate-y-1 transition-transform" />
          </a>
          <a
            href={localizedPath(lang, '/proyectos')}
            class="flex items-center justify-center gap-3 bg-white hover:bg-slate-50 text-slate-700 border-2 border-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700 dark:text-slate-100 dark:border-slate-700 px-10 py-5 rounded-2xl text-xl font-bold hover:-translate-y-1.5 transition-all duration-300 shadow-sm"
          >
            {t('hero.cta.projects')}
          </a>
        </div>
      </div>
    </div>

    <div class="relative lg:-mr-24 w-full">
      <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-cyan-400 rounded-2xl blur opacity-20"></div>

      <div class="relative bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl rounded-2xl shadow-2xl border border-white/50 dark:border-slate-700/50 overflow-hidden transform transition-transform duration-500 hover:scale-[1.01]">
        <div class="h-10 bg-slate-50/50 dark:bg-slate-800/50 border-b border-slate-100 dark:border-slate-700 flex items-center px-4 justify-between">
          <div class="flex gap-2">
            <div class="w-3 h-3 rounded-full bg-red-400"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
            <div class="w-3 h-3 rounded-full bg-green-400"></div>
          </div>
          <div class="px-3 py-1 bg-white dark:bg-slate-800 rounded-md border border-slate-100 dark:border-slate-700 text-[10px] text-slate-400 dark:text-slate-500 font-mono shadow-sm">
            ferser-admin-panel.tsx
          </div>
        </div>

        <div class="flex h-[400px]">
          <div class="w-16 md:w-48 border-r border-slate-100 dark:border-slate-700 p-4 flex flex-col gap-4 bg-slate-50/30 dark:bg-slate-800/30">
            <div class="h-8 w-16 bg-blue-600 rounded-lg mb-4 flex items-center justify-center text-white font-bold">
              Ferser
            </div>
            <div class="h-2 w-20 bg-slate-200 dark:bg-slate-700 rounded"></div>
            <div class="h-2 w-24 bg-slate-200 dark:bg-slate-700 rounded"></div>
            <div class="h-2 w-16 bg-slate-200 dark:bg-slate-700 rounded"></div>
            <div class="mt-auto h-8 w-8 rounded-full bg-slate-200 dark:bg-slate-700"></div>
          </div>

          <div class="flex-1 p-6 bg-white/50 dark:bg-slate-900/50">
            <div class="flex justify-between items-center mb-6">
              <div>
                <p class="font-bold text-slate-800 dark:text-slate-100 text-lg">{t('panel.title')}</p>
                <p class="text-xs text-slate-500 dark:text-slate-400">{t('panel.updated')}</p>
              </div>
              <button class="bg-blue-600 dark:bg-blue-500 text-white text-xs px-3 py-1.5 rounded-lg">
                {t('panel.export')}
              </button>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div class="col-span-2 bg-white dark:bg-slate-800 p-4 rounded-xl border border-slate-100 dark:border-slate-700 shadow-sm">
                <div class="flex justify-between mb-4">
                  <span class="text-xs font-semibold text-slate-600 dark:text-slate-300">{t('panel.api_traffic')}</span>
                  <span class="text-xs text-green-500 font-bold">+24.5%</span>
                </div>
                <div class="flex items-end gap-2 h-24">
                  <div class="w-full bg-blue-50 dark:bg-blue-900/30 h-[40%] rounded-sm"></div>
                  <div class="w-full bg-blue-100 dark:bg-blue-800/40 h-[60%] rounded-sm"></div>
                  <div class="w-full bg-blue-200 dark:bg-blue-700/60 h-[30%] rounded-sm"></div>
                  <div class="w-full bg-blue-400 dark:bg-blue-500 h-[80%] rounded-sm shadow-lg shadow-blue-500/20"></div>
                  <div class="w-full bg-blue-300 dark:bg-blue-600/70 h-[50%] rounded-sm"></div>
                  <div class="w-full bg-blue-100 dark:bg-blue-800/40 h-[70%] rounded-sm"></div>
                  <div class="w-full bg-blue-50 dark:bg-blue-900/30 h-[45%] rounded-sm"></div>
                </div>
              </div>

              <div class="bg-white dark:bg-slate-800 p-4 rounded-xl border border-slate-100 dark:border-slate-700 shadow-sm">
                <div class="w-8 h-8 bg-purple-100 dark:bg-purple-900/40 text-purple-600 dark:text-purple-300 rounded-lg flex items-center justify-center mb-2">
                  <Icon name="database" class="w-4 h-4" />
                </div>
                <div class="text-2xl font-bold text-slate-800 dark:text-slate-100">98.2%</div>
                <div class="text-xs text-slate-500 dark:text-slate-400">{t('panel.uptime')}</div>
              </div>

              <div class="bg-white dark:bg-slate-800 p-4 rounded-xl border border-slate-100 dark:border-slate-700 shadow-sm">
                <div class="w-8 h-8 bg-cyan-100 dark:bg-cyan-900/40 text-cyan-600 dark:text-cyan-300 rounded-lg flex items-center justify-center mb-2">
                  <Icon name="zap" class="w-4 h-4" />
                </div>
                <div class="text-2xl font-bold text-slate-800 dark:text-slate-100">45ms</div>
                <div class="text-xs text-slate-500 dark:text-slate-400">{t('panel.latency')}</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="absolute -left-12 top-20 -z-10 bg-slate-900 dark:bg-slate-700 p-4 rounded-xl shadow-xl w-64 transform -rotate-6 opacity-90 hidden md:block">
        <div class="flex gap-1.5 mb-3">
          <div class="w-2 h-2 rounded-full bg-slate-600"></div>
          <div class="w-2 h-2 rounded-full bg-slate-600"></div>
        </div>
        <div class="space-y-2">
          <div class="h-2 w-24 bg-slate-700 rounded"></div>
          <div class="h-2 w-32 bg-purple-500/50 rounded"></div>
          <div class="h-2 w-20 bg-slate-700 rounded ml-4"></div>
        </div>
      </div>

      <div
        class="absolute -bottom-6 -right-6 bg-white dark:bg-slate-800 p-4 rounded-xl shadow-[0_10px_40px_-10px_rgba(0,0,0,0.1)] border border-slate-100 dark:border-slate-700 flex items-center gap-4 animate-bounce"
        style="animation-duration: 4s;"
      >
        <div class="bg-green-100 dark:bg-green-900/40 p-2.5 rounded-full text-green-600 dark:text-green-300 ring-4 ring-green-50 dark:ring-green-900/20">
          <Icon name="circle-check-big" class="w-6 h-6" />
        </div>
        <div>
          <div class="text-sm font-bold text-slate-800 dark:text-slate-100">{t('panel.deploy_success')}</div>
          <div class="text-xs text-slate-500 dark:text-slate-400">{t('panel.deploy_version')}</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="servicios" class="py-24 bg-white/50 dark:bg-slate-900/50 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-16 fade-in-up">
      <h2 class="text-3xl md:text-5xl font-bold text-slate-900 dark:text-white mb-4">{t('services.title')}</h2>
      <p class="text-lg text-slate-600 dark:text-slate-300">{t('services.subtitle')}</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((s, i) => (
        <a
          href={`${contactBase}?servicio=${s.key}`}
          class="group relative flex flex-col overflow-hidden p-8 bg-white dark:bg-slate-800 rounded-3xl border border-slate-100 dark:border-slate-700 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 fade-in-up"
          style={`transition-delay: ${i * 0.1}s;`}
        >
          <span class={`absolute inset-x-0 top-0 h-1 bg-gradient-to-r ${s.bar} origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-300`}></span>
          <div class={`w-14 h-14 ${s.iconWrap} rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform`}>
            <Icon name={s.icon} class="w-7 h-7" />
          </div>
          <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3">{t(s.title)}</h3>
          <p class="text-slate-600 dark:text-slate-300 leading-relaxed">{t(s.desc)}</p>
          <span class={`mt-auto pt-6 inline-flex items-center gap-1.5 text-sm font-bold ${s.cta}`}>
            {t('services.cta')}
            <Icon name="arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
