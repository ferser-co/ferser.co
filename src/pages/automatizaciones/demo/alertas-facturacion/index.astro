---
import '@fontsource-variable/inter';
import '../../../../styles/global.css';
import Icon from '../../../../components/Icon.astro';
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Alertas de facturación · Demo — Ferser</title>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#020617" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {/* Fuente Inter local (@fontsource-variable/inter, importada en frontmatter) */}
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-200 antialiased" style="font-family: 'Inter Variable', 'Inter', system-ui, sans-serif;">
    <header class="sticky top-0 z-20 border-b border-slate-800 bg-slate-900/80 backdrop-blur">
      <div class="max-w-7xl mx-auto px-5 h-14 flex items-center justify-between gap-4">
        <div class="flex items-center gap-2.5 min-w-0">
          <span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-gradient-to-br from-blue-600 to-cyan-500 text-white"><Icon name="bell-ring" class="w-4 h-4" /></span>
          <span class="font-bold text-white truncate">Alertas de facturación</span>
          <span class="hidden sm:inline rounded-full bg-slate-800 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-slate-400">Demo</span>
        </div>
        <div class="inline-flex rounded-full bg-slate-800 p-0.5 text-xs font-semibold" data-sectors>
          <button type="button" data-sector="gimnasio" class="px-3 py-1.5 rounded-full text-slate-300">Gimnasio</button>
          <button type="button" data-sector="restaurante" class="px-3 py-1.5 rounded-full text-slate-300">Restaurante</button>
          <button type="button" data-sector="oficina" class="px-3 py-1.5 rounded-full text-slate-300">Oficina</button>
        </div>
        <a href="/proyectos" data-back class="shrink-0 inline-flex items-center gap-1.5 rounded-lg border border-slate-700 px-3 py-1.5 text-sm font-semibold text-slate-300 hover:bg-slate-800 transition-colors">
          ← Volver
        </a>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-5 py-6">
      <div class="mb-6">
        <h1 class="text-xl font-black text-white" data-title>Facturación · Gimnasio</h1>
        <p class="text-sm text-slate-400">El sistema envía las notificaciones por sí solo, según el calendario de reglas y el canal que cada cliente eligió.</p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
        <div class="rounded-xl border border-slate-800 bg-slate-900 p-4">
          <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">Eventos procesados</p>
          <p class="mt-1 text-2xl font-black text-white" data-kpi-events>184</p>
        </div>
        <div class="rounded-xl border border-slate-800 bg-slate-900 p-4">
          <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">Mensajes enviados</p>
          <p class="mt-1 text-2xl font-black text-cyan-400" data-kpi-sent>206</p>
        </div>
        <div class="rounded-xl border border-slate-800 bg-slate-900 p-4">
          <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">Recuperación estimada</p>
          <p class="mt-1 text-2xl font-black text-emerald-400" data-kpi-recovery>COP 4.250.000</p>
        </div>
        <div class="rounded-xl border border-slate-800 bg-slate-900 p-4">
          <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">Prioridad alta</p>
          <p class="mt-1 text-2xl font-black text-rose-400" data-kpi-high>96</p>
        </div>
      </div>

      <div class="grid lg:grid-cols-3 gap-4">
        {/* Motor automático + configuración */}
        <section class="rounded-2xl border border-slate-800 bg-slate-900 p-5 flex flex-col">
          <div class="flex items-center justify-between mb-3">
            <h2 class="font-bold text-white">Motor automático</h2>
            <button type="button" data-toggle class="inline-flex items-center gap-2 rounded-full bg-emerald-500/15 px-3 py-1 text-xs font-bold text-emerald-400">
              <span class="h-2 w-2 rounded-full bg-emerald-500" data-toggle-dot></span>
              <span data-toggle-text>Activo</span>
            </button>
          </div>
          <p class="text-xs text-slate-400 mb-4" data-status>Enviando notificaciones según el calendario.</p>

          <span class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">Calendario de reglas</span>
          <div class="flex flex-col gap-1.5 mb-4" data-rules></div>

          <div class="grid grid-cols-2 gap-2">
            <button type="button" data-step class="rounded-lg border border-slate-700 px-3 py-2 text-sm font-semibold text-slate-200 hover:border-slate-600 transition">Procesar siguiente</button>
            <button type="button" data-reset class="rounded-lg border border-slate-700 px-3 py-2 text-sm font-semibold text-slate-400 hover:border-slate-600 transition">Reiniciar día</button>
          </div>
        </section>

        {/* Clientes */}
        <section class="lg:col-span-2 rounded-2xl border border-slate-800 bg-slate-900 overflow-hidden">
          <div class="px-5 py-3.5 border-b border-slate-800 flex items-center justify-between">
            <h2 class="font-bold text-white">Clientes con cobro recurrente</h2>
            <span class="text-xs text-slate-500">Toca el canal para cambiar la preferencia</span>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-xs uppercase tracking-wider text-slate-500 border-b border-slate-800">
                  <th class="font-semibold px-5 py-2.5">Cliente</th>
                  <th class="font-semibold px-3 py-2.5">Motivo</th>
                  <th class="font-semibold px-3 py-2.5">Canal</th>
                  <th class="font-semibold px-3 py-2.5">Estado</th>
                </tr>
              </thead>
              <tbody data-clients></tbody>
            </table>
          </div>
        </section>
      </div>

      {/* Envío manual */}
      <section class="mt-4 rounded-2xl border border-slate-800 bg-slate-900 p-5">
        <div class="flex items-center justify-between mb-1">
          <h2 class="font-bold text-white">Envío manual</h2>
          <span class="text-xs text-slate-500">Aviso puntual, fuera del calendario</span>
        </div>
        <p class="text-xs text-slate-400 mb-4">Elige cliente, mensaje y canal, y envíalo al instante.</p>
        <div class="grid lg:grid-cols-2 gap-5">
          <div class="flex flex-col gap-3">
            <label class="block text-xs font-semibold uppercase tracking-wider text-slate-500">
              Cliente
              <select data-m-client class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-800 px-3 py-2 text-sm font-medium text-slate-200"></select>
            </label>
            <label class="block text-xs font-semibold uppercase tracking-wider text-slate-500">
              Mensaje
              <select data-m-event class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-800 px-3 py-2 text-sm font-medium text-slate-200">
                <option value="charge_failed">Cargo rechazado</option>
                <option value="subscription_expired">Suscripción vencida</option>
                <option value="card_expiring">Tarjeta por vencer</option>
              </select>
            </label>
            <div>
              <span class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-1">Canal</span>
              <div class="grid grid-cols-3 gap-2" data-m-channels>
                <button type="button" data-m-channel="whatsapp" class="rounded-lg border px-3 py-2 text-sm font-semibold transition border-blue-500 bg-blue-500/15 text-blue-300">WhatsApp</button>
                <button type="button" data-m-channel="email" class="rounded-lg border px-3 py-2 text-sm font-semibold transition border-slate-700 text-slate-300 hover:border-slate-600">Correo</button>
                <button type="button" data-m-channel="both" class="rounded-lg border px-3 py-2 text-sm font-semibold transition border-slate-700 text-slate-300 hover:border-slate-600">Ambos</button>
              </div>
            </div>
            <button type="button" data-m-send class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-br from-blue-600 to-cyan-500 px-4 py-3 text-sm font-bold text-white hover:brightness-110 transition">Enviar ahora</button>
          </div>
          <div>
            <span class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-1">Último mensaje enviado</span>
            <div class="rounded-xl border border-dashed border-slate-700 p-4 min-h-[150px] flex items-center justify-center" data-preview>
              <p class="text-sm text-slate-500 text-center">Aquí se muestra el último mensaje enviado (automático o manual).</p>
            </div>
          </div>
        </div>
      </section>

      {/* Cola */}
      <section class="mt-4 rounded-2xl border border-slate-800 bg-slate-900 overflow-hidden">
        <div class="px-5 py-3.5 border-b border-slate-800 flex items-center gap-2">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-cyan-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-cyan-500"></span>
          </span>
          <h2 class="font-bold text-white">Cola de mensajería en vivo</h2>
        </div>
        <ul class="divide-y divide-slate-800 max-h-72 overflow-y-auto" data-queue>
          <li class="px-5 py-3 text-sm text-slate-500">El motor irá registrando aquí cada envío.</li>
        </ul>
      </section>
    </main>

    <script>
      const RULES = {
        charge_failed: { label: "Cargo rechazado", timing: "inmediato", priority: "high" },
        subscription_expired: { label: "Suscripción vencida", timing: "día del vencimiento", priority: "high" },
        card_expiring: { label: "Tarjeta por vencer", timing: "7 días antes", priority: "medium" },
      };

      const BASE_CLIENTS = [
        { id: "C-204", factor: 1.0, channel: "whatsapp", rule: "charge_failed" },
        { id: "C-118", factor: 1.6, channel: "email", rule: "subscription_expired" },
        { id: "C-377", factor: 0.8, channel: "both", rule: "card_expiring" },
        { id: "C-090", factor: 2.0, channel: "email", rule: "charge_failed" },
        { id: "C-251", factor: 1.2, channel: "whatsapp", rule: "none" },
        { id: "C-432", factor: 0.6, channel: "both", rule: "subscription_expired" },
      ];

      const SECTORS = {
        gimnasio: {
          title: "Facturación · Gimnasio", business: "FitZone", base: 80000,
          names: { "C-204": "Ana Restrepo", "C-118": "Carlos Mora", "C-377": "Luisa Peña", "C-090": "Pedro Gómez", "C-251": "Sofía Lara", "C-432": "Andrés Ruiz" },
        },
        restaurante: {
          title: "Facturación · Restaurante", business: "La Terraza", base: 150000,
          names: { "C-204": "Socio Gold", "C-118": "Mesa corporativa", "C-377": "Cliente frecuente", "C-090": "Evento privado", "C-251": "Socio Plata", "C-432": "Reserva mensual" },
        },
        oficina: {
          title: "Facturación · Oficina", business: "WorkHub", base: 320000,
          names: { "C-204": "M. Álvarez", "C-118": "Estudio creativo", "C-377": "J. Torres", "C-090": "Equipo de 8", "C-251": "Dir. de TI", "C-432": "Freelancer" },
        },
      };

      const $ = (s) => document.querySelector(s);
      const kpi = { events: 184, sent: 206, recovery: 4250000, high: 96 };

      let sector = "gimnasio";
      let clients = [];
      let auto = true;
      let timer = null;
      let manualChannel = "whatsapp";

      function money(n) { return "COP " + n.toLocaleString("es-CO"); }
      function amountOf(c) { return Math.round((SECTORS[sector].base * c.factor) / 1000) * 1000; }
      function resetClients() { clients = BASE_CLIENTS.map((c) => ({ ...c, sent: false })); }

      function buildBody(ruleKey, ch, name, business, amount) {
        const amt = " por " + money(amount);
        if (ruleKey === "charge_failed") {
          return ch === "whatsapp"
            ? `Hola ${name}, intentamos cobrar tu plan${amt} y el pago fue rechazado. Actualiza tu medio de pago para no perder el servicio.`
            : `Hola ${name},\n\nIntentamos procesar el cobro de tu plan${amt} y fue rechazado. Actualiza tu medio de pago para mantener tu servicio activo.\n\nEquipo de ${business}.`;
        }
        if (ruleKey === "subscription_expired") {
          return ch === "whatsapp"
            ? `Hola ${name}, tu suscripción venció. Renuévala hoy y sigue disfrutando de tus beneficios sin interrupciones.`
            : `Hola ${name},\n\nTu suscripción llegó a su vencimiento. Renuévala para no perder el acceso a tu servicio.\n\nEquipo de ${business}.`;
        }
        return ch === "whatsapp"
          ? `Hola ${name}, la tarjeta registrada para tu plan está por vencer. Actualízala para evitar que se interrumpa el cobro.`
          : `Hola ${name},\n\nLa tarjeta asociada a tu plan está próxima a vencer. Actualiza tus datos de pago para evitar rechazos.\n\nEquipo de ${business}.`;
      }

      function channelLabel(ch) {
        if (ch === "whatsapp") return ["WhatsApp", "bg-emerald-500/15 text-emerald-400"];
        if (ch === "email") return ["Correo", "bg-blue-500/15 text-blue-300"];
        return ["Ambos", "bg-indigo-500/15 text-indigo-300"];
      }

      function renderRules() {
        const el = $("[data-rules]");
        el.innerHTML = "";
        for (const k of Object.keys(RULES)) {
          const r = RULES[k];
          const row = document.createElement("div");
          row.className = "flex items-center justify-between rounded-lg bg-slate-800/50 px-3 py-1.5 text-xs";
          row.innerHTML = `<span class="text-slate-200">${r.label}</span><span class="${r.priority === "high" ? "text-rose-400" : "text-amber-400"}">${r.timing}</span>`;
          el.appendChild(row);
        }
      }

      function cycleChannel(ch) { return ch === "whatsapp" ? "email" : ch === "email" ? "both" : "whatsapp"; }

      function renderClients() {
        const body = $("[data-clients]");
        const names = SECTORS[sector].names;
        body.innerHTML = "";
        for (const c of clients) {
          const tr = document.createElement("tr");
          tr.dataset.row = c.id;
          tr.className = "border-b border-slate-800/60 transition-colors";
          const motivo = c.rule === "none"
            ? `<span class="text-slate-500">Al día</span>`
            : `<span class="text-slate-200">${RULES[c.rule].label}</span> <span class="text-slate-500">· ${RULES[c.rule].timing}</span>`;
          const [chLabel, chCls] = channelLabel(c.channel);
          const estado = c.rule === "none"
            ? `<span class="text-slate-600 text-xs">—</span>`
            : c.sent
              ? `<span class="inline-flex items-center gap-1 text-emerald-400 text-xs font-semibold">Enviado</span>`
              : `<span class="inline-flex items-center gap-1 text-amber-400 text-xs font-semibold">Pendiente</span>`;
          tr.innerHTML =
            `<td class="px-5 py-3"><div class="font-semibold text-slate-100">${names[c.id]}</div><div class="text-xs text-slate-500 font-mono">${c.id} · ${money(amountOf(c))}</div></td>` +
            `<td class="px-3 py-3 text-xs">${motivo}</td>` +
            `<td class="px-3 py-3"><button type="button" data-chan="${c.id}" class="rounded-full px-2 py-0.5 text-[11px] font-semibold ${chCls} hover:brightness-110">${chLabel}</button></td>` +
            `<td class="px-3 py-3">${estado}</td>`;
          body.appendChild(tr);
        }
        body.querySelectorAll("[data-chan]").forEach((btn) => {
          btn.addEventListener("click", () => {
            const c = clients.find((x) => x.id === btn.dataset.chan);
            c.channel = cycleChannel(c.channel);
            renderClients();
          });
        });
      }

      function highlightRow(id) {
        const tr = document.querySelector(`[data-row="${id}"]`);
        if (!tr) return;
        tr.classList.add("bg-cyan-500/10", "ring-1", "ring-inset", "ring-cyan-500/40");
        setTimeout(() => tr.classList.remove("bg-cyan-500/10", "ring-1", "ring-inset", "ring-cyan-500/40"), 1600);
      }

      function updateKpis() {
        $("[data-kpi-events]").textContent = kpi.events;
        $("[data-kpi-sent]").textContent = kpi.sent;
        $("[data-kpi-recovery]").textContent = money(kpi.recovery);
        $("[data-kpi-high]").textContent = kpi.high;
      }

      function renderPreview(ch, name, ruleKey, body) {
        const el = $("[data-preview]");
        el.classList.remove("items-center", "justify-center", "border-dashed");
        el.classList.add("items-stretch", "border-solid");
        const [chLabel] = channelLabel(ch);
        if (ch === "whatsapp") {
          el.innerHTML = `<div class="self-start max-w-full rounded-xl rounded-bl-sm bg-emerald-600/20 border border-emerald-500/30 px-3 py-2.5 text-sm text-emerald-50 whitespace-pre-wrap leading-relaxed">${body}</div>`;
        } else {
          el.innerHTML =
            `<div class="w-full rounded-xl border border-slate-700 overflow-hidden">` +
            `<div class="bg-slate-800 px-3 py-2 text-xs font-semibold text-slate-300 border-b border-slate-700">Correo · ${RULES[ruleKey].label}</div>` +
            `<div class="px-3 py-2.5 text-sm text-slate-300 whitespace-pre-wrap leading-relaxed">${body}</div></div>`;
        }
      }

      function queueEntry(ch, name, ruleKey, source = "auto") {
        const queue = $("[data-queue]");
        const placeholder = queue.querySelector("li.text-slate-500");
        if (placeholder && queue.children.length === 1) placeholder.remove();
        const r = RULES[ruleKey];
        const [chLabel, chCls] = channelLabel(ch);
        const t = new Date().toLocaleTimeString("es-CO", { hour: "2-digit", minute: "2-digit", second: "2-digit" });
        const li = document.createElement("li");
        li.className = "px-5 py-2.5 text-sm flex items-center gap-3";
        li.innerHTML =
          `<span class="rounded-full px-2 py-0.5 text-[11px] font-semibold ${chCls}">${chLabel}</span>` +
          `<span class="text-slate-300">${name}</span>` +
          `<span class="text-slate-500">— ${r.label}</span>` +
          `<span class="rounded bg-slate-800 px-1.5 py-0.5 text-[10px] font-semibold ${source === "manual" ? "text-cyan-300" : "text-slate-400"}">${source}</span>` +
          `<span class="ml-auto text-xs text-slate-600 tabular-nums">${t}</span>`;
        queue.prepend(li);
      }

      function processNext() {
        const c = clients.find((x) => x.rule !== "none" && !x.sent);
        if (!c) {
          $("[data-status]").textContent = auto ? "Sin pendientes. Todo al día." : "Pausado. Sin pendientes.";
          return false;
        }
        const name = SECTORS[sector].names[c.id];
        const business = SECTORS[sector].business;
        const amount = amountOf(c);
        const r = RULES[c.rule];
        const channels = c.channel === "both" ? ["whatsapp", "email"] : [c.channel];

        let lastCh = channels[0], lastBody = "";
        for (const ch of channels) {
          const body = buildBody(c.rule, ch, name, business, amount);
          queueEntry(ch, name, c.rule);
          kpi.sent += 1;
          lastCh = ch; lastBody = body;
        }
        kpi.events += 1;
        if (c.rule !== "card_expiring") kpi.recovery += amount;
        if (r.priority === "high") kpi.high += 1;

        c.sent = true;
        updateKpis();
        renderClients();
        highlightRow(c.id);
        renderPreview(lastCh, name, c.rule, lastBody);
        $("[data-status]").textContent = auto ? "Enviando notificaciones según el calendario." : "Procesado un envío manualmente.";
        return true;
      }

      function setAuto(on) {
        auto = on;
        if (timer) { clearInterval(timer); timer = null; }
        const dot = $("[data-toggle-dot]"), text = $("[data-toggle-text]"), btn = $("[data-toggle]");
        if (on) {
          dot.className = "h-2 w-2 rounded-full bg-emerald-500";
          btn.className = "inline-flex items-center gap-2 rounded-full bg-emerald-500/15 px-3 py-1 text-xs font-bold text-emerald-400";
          text.textContent = "Activo";
          $("[data-status]").textContent = "Enviando notificaciones según el calendario.";
          timer = setInterval(processNext, 2200);
        } else {
          dot.className = "h-2 w-2 rounded-full bg-slate-500";
          btn.className = "inline-flex items-center gap-2 rounded-full bg-slate-700/50 px-3 py-1 text-xs font-bold text-slate-400";
          text.textContent = "Pausado";
          $("[data-status]").textContent = "Pausado. Usa “Procesar siguiente” para envío manual.";
        }
      }

      function renderManualClients() {
        const sel = $("[data-m-client]");
        const names = SECTORS[sector].names;
        const current = sel.value;
        sel.innerHTML = "";
        for (const c of BASE_CLIENTS) {
          const opt = document.createElement("option");
          opt.value = c.id;
          opt.textContent = names[c.id] + " · " + c.id;
          sel.appendChild(opt);
        }
        if (current && [...sel.options].some((o) => o.value === current)) sel.value = current;
      }

      function setManualChannel(ch) {
        manualChannel = ch;
        document.querySelectorAll("[data-m-channel]").forEach((b) => {
          const on = b.dataset.mChannel === ch;
          b.classList.toggle("border-blue-500", on);
          b.classList.toggle("bg-blue-500/15", on);
          b.classList.toggle("text-blue-300", on);
          b.classList.toggle("border-slate-700", !on);
          b.classList.toggle("text-slate-300", !on);
        });
      }

      function sendManual() {
        const clientId = $("[data-m-client]").value;
        const eventKey = $("[data-m-event]").value;
        const client = clients.find((x) => x.id === clientId) || BASE_CLIENTS.find((x) => x.id === clientId);
        if (!client) return;
        const name = SECTORS[sector].names[clientId];
        const business = SECTORS[sector].business;
        const amount = amountOf(client);
        const channels = manualChannel === "both" ? ["whatsapp", "email"] : [manualChannel];

        let lastCh = channels[0], lastBody = "";
        for (const ch of channels) {
          const body = buildBody(eventKey, ch, name, business, amount);
          queueEntry(ch, name, eventKey, "manual");
          kpi.sent += 1;
          lastCh = ch; lastBody = body;
        }
        kpi.events += 1;
        if (eventKey !== "card_expiring") kpi.recovery += amount;
        if (RULES[eventKey].priority === "high") kpi.high += 1;
        updateKpis();
        highlightRow(clientId);
        renderPreview(lastCh, name, eventKey, lastBody);
      }

      function render() {
        $("[data-title]").textContent = SECTORS[sector].title;
        renderRules();
        renderClients();
        renderManualClients();
      }

      document.querySelectorAll("[data-sector]").forEach((btn) => {
        btn.addEventListener("click", () => {
          sector = btn.dataset.sector;
          resetClients();
          document.querySelectorAll("[data-sector]").forEach((b) => {
            const on = b === btn;
            b.classList.toggle("bg-white", on);
            b.classList.toggle("text-slate-900", on);
            b.classList.toggle("text-slate-300", !on);
          });
          render();
        });
      });
      const firstSector = document.querySelector('[data-sector="gimnasio"]');
      firstSector.classList.add("bg-white", "text-slate-900");
      firstSector.classList.remove("text-slate-300");

      $("[data-toggle]").addEventListener("click", () => setAuto(!auto));
      $("[data-step]").addEventListener("click", processNext);
      $("[data-reset]").addEventListener("click", () => {
        resetClients();
        renderClients();
        $("[data-status]").textContent = auto ? "Enviando notificaciones según el calendario." : "Pausado. Listo para procesar.";
      });

      document.querySelectorAll("[data-m-channel]").forEach((b) => b.addEventListener("click", () => setManualChannel(b.dataset.mChannel)));
      $("[data-m-client]").addEventListener("change", () => {
        const c = BASE_CLIENTS.find((x) => x.id === $("[data-m-client]").value);
        if (c) setManualChannel(c.channel);
      });
      $("[data-m-send]").addEventListener("click", sendManual);

      $("[data-back]").addEventListener("click", (e) => {
        if (window.opener && !window.opener.closed) {
          e.preventDefault();
          try { window.opener.focus(); } catch (_) {}
          window.close();
        }
      });

      resetClients();
      updateKpis();
      render();
      setManualChannel((BASE_CLIENTS.find((x) => x.id === $("[data-m-client]").value) || BASE_CLIENTS[0]).channel);
      setAuto(true);
    </script>
  </body>
</html>
