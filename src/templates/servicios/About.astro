---
import type { ServiciosData } from './data';

import Icon from '../../components/Icon.astro';
interface Props {
  data: ServiciosData;
}

const { data } = Astro.props;
---

<section id="nosotros" class="py-20 sm:py-28 bg-slate-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">
      <div class="reveal">
        <p class="mb-3 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-blue-900">
          <span class="h-px w-8 bg-blue-900"></span>
          {data.about.eyebrow}
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight text-slate-900 mb-6">
          {data.about.title}
        </h2>
        <div class="space-y-5">
          {data.about.paragraphs.map((p) => (
            <p class="text-base sm:text-lg text-slate-600 leading-relaxed">{p}</p>
          ))}
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-5 self-center">
        {data.about.pillars.map((pillar, i) => (
          <div
            class="reveal p-6 bg-white rounded-2xl border border-slate-200"
            style={`transition-delay: ${i * 80}ms;`}
          >
            <div class="w-9 h-9 rounded-lg bg-blue-900 text-white flex items-center justify-center mb-4">
              <Icon name="check" class="w-5 h-5" />
            </div>
            <h3 class="text-base font-bold text-slate-900 mb-1.5">{pillar.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{pillar.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
