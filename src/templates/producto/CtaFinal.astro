---
import type { ProductoData } from './data';

import Icon from '../../components/Icon.astro';
interface Props {
  data: ProductoData;
}

const { data } = Astro.props;
---

<section class="py-20 sm:py-24 relative overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-gradient-to-br from-indigo-600 via-violet-600 to-fuchsia-600"></div>
  <div class="absolute top-[-100px] right-[-100px] -z-10 w-[400px] h-[400px] rounded-full bg-white/10 blur-3xl"></div>
  <div class="absolute bottom-[-150px] left-[-100px] -z-10 w-[500px] h-[500px] rounded-full bg-white/10 blur-3xl"></div>

  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center reveal">
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tighter text-white mb-4">
      {data.ctaFinal.title}
    </h2>
    <p class="text-lg sm:text-xl text-indigo-100 mb-10">{data.ctaFinal.subtitle}</p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href={data.ctaFinal.primaryCta.href}
        class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-7 py-4 text-base font-bold text-indigo-700 shadow-xl hover:bg-indigo-50 hover:-translate-y-0.5 transition-all"
      >
        {data.ctaFinal.primaryCta.label}
        <Icon name="arrow-right" class="w-4 h-4" />
      </a>
      {data.ctaFinal.secondaryCta && (
        <a
          href={data.ctaFinal.secondaryCta.href}
          class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-white/40 bg-white/10 backdrop-blur px-7 py-4 text-base font-semibold text-white hover:bg-white/20 transition-all"
        >
          {data.ctaFinal.secondaryCta.label}
        </a>
      )}
    </div>
  </div>
</section>
