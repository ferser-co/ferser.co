---
import type { ProductoData } from './data';

import Icon from '../../components/Icon.astro';
interface Props {
  data: ProductoData;
}

const { data } = Astro.props;

const socialIcon: Record<string, string> = {
  linkedin: 'linkedin',
  facebook: 'facebook',
  instagram: 'instagram',
  twitter: 'twitter',
  whatsapp: 'message-circle',
  github: 'github',
};
---

<footer class="bg-slate-950 text-slate-300">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1.5fr_2fr] gap-12">
      <div class="max-w-md">
        <div class="flex items-center gap-2.5 mb-4">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-indigo-500 to-violet-500 text-base font-black text-white">
            {data.brand.initial}
          </span>
          <span class="text-base font-extrabold tracking-tight text-white">{data.brand.name}</span>
        </div>
        <p class="text-sm leading-relaxed text-slate-400 mb-6">{data.footer.description}</p>

        <div class="flex gap-3">
          {data.footer.socials.map((s) => (
            <a
              href={s.url}
              aria-label={s.type}
              class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-slate-900 hover:bg-indigo-600 transition-colors"
            >
              <Icon name={socialIcon[s.type] ?? 'link'} class="w-4 h-4" />
            </a>
          ))}
        </div>
      </div>

      <div class="grid sm:grid-cols-3 gap-8">
        {data.footer.columns.map((col) => (
          <div>
            <p class="text-xs font-bold uppercase tracking-wider text-slate-500 mb-4">{col.title}</p>
            <ul class="space-y-2.5">
              {col.links.map((link) => (
                <li>
                  <a href={link.href} class="text-sm text-slate-400 hover:text-white transition-colors">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-slate-800 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs text-slate-500">{data.footer.copyright}</p>
      <p class="text-xs text-slate-500">
        Hecho con
        <a href="https://ferser.co" class="text-slate-300 hover:text-white font-semibold transition-colors">Ferser</a>
      </p>
    </div>
  </div>
</footer>
