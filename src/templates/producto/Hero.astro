---
import type { ProductoData } from './data';

import Icon from '../../components/Icon.astro';
interface Props {
  data: ProductoData;
}

const { data } = Astro.props;
---

<section id="top" class="relative overflow-hidden pt-32 pb-20 sm:pt-40">
  {/* Soft gradient bg */}
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-indigo-50/40 via-white to-white"></div>
  <div class="absolute top-20 right-[-200px] -z-10 w-[600px] h-[600px] rounded-full bg-violet-200/30 blur-3xl"></div>
  <div class="absolute top-40 left-[-150px] -z-10 w-[500px] h-[500px] rounded-full bg-indigo-200/30 blur-3xl"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center">
      <div class="reveal">
        <p class="mb-5 inline-flex items-center gap-2 rounded-full border border-indigo-200 bg-indigo-50 px-3.5 py-1.5 text-xs font-bold text-indigo-700">
          <span class="relative flex h-1.5 w-1.5">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-indigo-400 opacity-75"></span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-indigo-600"></span>
          </span>
          {data.hero.eyebrow}
        </p>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black leading-[1.05] tracking-tighter text-slate-900 mb-6">
          {data.hero.title}{' '}
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 via-violet-600 to-fuchsia-600">
            {data.hero.titleAccent}
          </span>
        </h1>

        <p class="text-lg sm:text-xl text-slate-600 leading-relaxed mb-10 max-w-xl">
          {data.hero.subtitle}
        </p>

        <div class="flex flex-col sm:flex-row gap-3 mb-8">
          <a
            href={data.hero.primaryCta.href}
            class="inline-flex items-center justify-center gap-2 rounded-lg bg-gradient-to-br from-indigo-600 to-violet-600 px-7 py-4 text-base font-bold text-white shadow-lg shadow-indigo-500/25 hover:shadow-xl hover:shadow-indigo-500/40 hover:-translate-y-0.5 transition-all"
          >
            {data.hero.primaryCta.label}
            <Icon name="arrow-right" class="w-4 h-4" />
          </a>
          {data.hero.secondaryCta && (
            <a
              href={data.hero.secondaryCta.href}
              class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-slate-200 bg-white px-7 py-4 text-base font-semibold text-slate-700 hover:border-slate-300 hover:bg-slate-50 transition-all"
            >
              <Icon name="circle-play" class="w-4 h-4" />
              {data.hero.secondaryCta.label}
            </a>
          )}
        </div>

        <div class="inline-flex items-center gap-2.5 text-sm text-slate-500">
          <div class="flex -space-x-2">
            <div class="h-7 w-7 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 border-2 border-white"></div>
            <div class="h-7 w-7 rounded-full bg-gradient-to-br from-emerald-400 to-teal-500 border-2 border-white"></div>
            <div class="h-7 w-7 rounded-full bg-gradient-to-br from-violet-400 to-fuchsia-500 border-2 border-white"></div>
            <div class="h-7 w-7 rounded-full bg-gradient-to-br from-sky-400 to-indigo-500 border-2 border-white"></div>
          </div>
          <span class="font-semibold text-slate-700">{data.hero.socialProof}</span>
        </div>
      </div>

      {/* Mockup */}
      <div class="reveal" style="transition-delay: 150ms;">
        <div class="relative">
          {/* Glow */}
          <div class="absolute -inset-2 bg-gradient-to-r from-indigo-500 to-violet-500 rounded-3xl blur-2xl opacity-20"></div>

          {/* Invoice card */}
          <div class="relative bg-white border border-slate-200 rounded-2xl shadow-2xl p-6 transform -rotate-1">
            <div class="flex items-center justify-between mb-5 pb-4 border-b border-slate-100">
              <div>
                <p class="text-xs text-slate-400 uppercase tracking-wider font-bold">Factura #0247</p>
                <p class="text-sm font-bold text-slate-900 mt-0.5">Restaurante La Roca S.A.S</p>
              </div>
              <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-bold text-emerald-700">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                Pagada
              </span>
            </div>

            <div class="space-y-2.5 mb-5">
              <div class="flex justify-between text-sm">
                <span class="text-slate-600">Consultoría mensual</span>
                <span class="font-semibold text-slate-900">$2.400.000</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-slate-600">IVA 19%</span>
                <span class="font-semibold text-slate-900">$456.000</span>
              </div>
              <div class="flex justify-between pt-2.5 border-t border-slate-100">
                <span class="font-bold text-slate-900">Total</span>
                <span class="font-black text-slate-900 text-lg">$2.856.000</span>
              </div>
            </div>

            <div class="flex items-center justify-between pt-4 border-t border-slate-100">
              <div class="flex items-center gap-2 text-xs text-slate-500">
                <Icon name="shield-check" class="w-4 h-4 text-emerald-500" />
                Validada por DIAN
              </div>
              <div class="flex items-center gap-1.5 text-xs font-semibold text-indigo-700">
                Ver detalle
                <Icon name="arrow-right" class="w-3 h-3" />
              </div>
            </div>
          </div>

          {/* Floating notification */}
          <div class="absolute -bottom-4 -right-4 sm:-right-6 bg-white rounded-2xl shadow-2xl border border-slate-100 p-3 pr-5 flex items-center gap-3 transform rotate-2">
            <div class="shrink-0 w-9 h-9 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center">
              <Icon name="circle-check-big" class="w-5 h-5" />
            </div>
            <div>
              <p class="text-xs font-bold text-slate-900">Pago recibido</p>
              <p class="text-[10px] text-slate-500">vía Nequi · hace 1 min</p>
            </div>
          </div>

          {/* Floating stat */}
          <div class="absolute -top-4 -left-4 sm:-left-6 bg-gradient-to-br from-indigo-600 to-violet-600 rounded-2xl p-4 shadow-2xl text-white transform -rotate-2">
            <p class="text-2xl font-black leading-none">$8.4M</p>
            <p class="text-[10px] opacity-90 mt-1 font-semibold">facturado este mes</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{/* Trusted by */}
<section class="py-12 bg-slate-50/50 border-y border-slate-100">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <p class="text-center text-xs font-bold uppercase tracking-wider text-slate-400 mb-6">{data.trustedBy.label}</p>
    <div class="flex flex-wrap items-center justify-center gap-8 lg:gap-12">
      {data.trustedBy.logos.map((logo) => (
        <span class="text-lg sm:text-xl font-bold tracking-tight text-slate-400 hover:text-slate-600 transition-colors">
          {logo}
        </span>
      ))}
    </div>
  </div>
</section>
