---
import type { ProductoData } from './data';

interface Props {
  data: ProductoData;
}

const { data } = Astro.props;
---

<section id="como-funciona" class="py-20 sm:py-28 bg-gradient-to-b from-indigo-50/40 via-white to-white">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-14 reveal">
      <p class="mb-3 inline-flex items-center gap-1.5 rounded-full bg-indigo-50 px-3 py-1 text-xs font-bold uppercase tracking-wider text-indigo-700">
        {data.howItWorks.eyebrow}
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tighter text-slate-900 mb-4">
        {data.howItWorks.title}
      </h2>
      <p class="text-base sm:text-lg text-slate-600">{data.howItWorks.subtitle}</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      {data.howItWorks.steps.map((step, i) => (
        <article
          class="reveal relative p-7 bg-white border border-slate-200 rounded-2xl shadow-sm"
          style={`transition-delay: ${i * 100}ms;`}
        >
          <div class="absolute -top-4 left-7 inline-flex h-9 w-9 items-center justify-center rounded-full bg-gradient-to-br from-indigo-600 to-violet-600 text-white font-black shadow-lg shadow-indigo-500/30">
            {i + 1}
          </div>
          <h3 class="mt-4 text-xl font-bold text-slate-900 mb-2">{step.title}</h3>
          <p class="text-sm sm:text-base text-slate-600 leading-relaxed">{step.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
