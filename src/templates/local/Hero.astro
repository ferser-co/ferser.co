---
import type { LocalData } from './data';

import Icon from '../../components/Icon.astro';
interface Props {
  data: LocalData;
}

const { data } = Astro.props;
---

<section id="top" class="relative min-h-[85vh] flex items-center overflow-hidden">
  {/* Background image with overlay */}
  <div
    class="absolute inset-0 -z-10 bg-cover bg-center"
    style={`background-image: url('${data.hero.backgroundImage}');`}
  ></div>
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-stone-900/80 via-stone-900/60 to-stone-900/85"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-32 pb-20 w-full">
    <div class="max-w-3xl reveal">
      <p class="mb-5 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-amber-300">
        <span class="h-px w-8 bg-amber-300"></span>
        {data.hero.eyebrow}
      </p>

      <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.05] tracking-tight text-white mb-6">
        {data.hero.title}
      </h1>

      <p class="text-lg sm:text-xl text-stone-200 leading-relaxed mb-10 max-w-xl">
        {data.hero.subtitle}
      </p>

      <div class="flex flex-col sm:flex-row gap-3">
        <a
          href={data.hero.primaryCta.href}
          class="inline-flex items-center justify-center gap-2 rounded-full bg-amber-500 px-7 py-4 text-base font-bold text-stone-900 shadow-xl shadow-amber-500/20 hover:bg-amber-400 hover:scale-[1.02] transition-all"
        >
          <Icon name="message-circle" class="w-5 h-5" />
          {data.hero.primaryCta.label}
        </a>
        {data.hero.secondaryCta && (
          <a
            href={data.hero.secondaryCta.href}
            class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-white/30 bg-white/10 backdrop-blur px-7 py-4 text-base font-semibold text-white hover:bg-white/20 transition-all"
          >
            {data.hero.secondaryCta.label}
            <Icon name="arrow-down" class="w-4 h-4" />
          </a>
        )}
      </div>
    </div>
  </div>
</section>
