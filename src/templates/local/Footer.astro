---
import type { LocalData } from './data';

import Icon from '../../components/Icon.astro';
interface Props {
  data: LocalData;
}

const { data } = Astro.props;

const socialIcon: Record<string, string> = {
  linkedin: 'linkedin',
  facebook: 'facebook',
  instagram: 'instagram',
  twitter: 'twitter',
  whatsapp: 'message-circle',
  github: 'github',
};
---

<footer class="bg-stone-950 text-stone-300">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
    <div class="flex flex-col sm:flex-row justify-between items-start gap-8">
      <div class="max-w-md">
        <div class="flex items-center gap-2.5 mb-4">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-amber-500 text-base font-black text-stone-900">
            {data.brand.initial}
          </span>
          <span class="text-base font-display font-bold tracking-tight text-white">{data.brand.name}</span>
        </div>
        <p class="text-sm leading-relaxed text-stone-400">{data.footer.description}</p>
      </div>

      <div class="flex gap-3">
        {data.footer.socials.map((s) => (
          <a
            href={s.url}
            aria-label={s.type}
            class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-stone-800 hover:bg-amber-500 hover:text-stone-900 transition-colors"
          >
            <Icon name={socialIcon[s.type] ?? 'link'} class="w-4 h-4" />
          </a>
        ))}
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-stone-800 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs text-stone-500">{data.footer.copyright}</p>
      <p class="text-xs text-stone-500">
        Hecho con
        <a href="https://ferser.co" class="text-stone-300 hover:text-amber-500 font-semibold transition-colors">Ferser</a>
      </p>
    </div>
  </div>
</footer>
