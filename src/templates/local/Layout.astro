---
import '@fontsource-variable/inter';
import '@fontsource-variable/playfair-display';
import '../_shared/base.css';

interface Props {
  title: string;
  description: string;
  isDemo?: boolean;
  noindex?: boolean;
  heroPreload?: string;
}

const { title, description, isDemo = false, noindex = false, heroPreload } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#92400e" />

    {/* Fuentes locales: Inter + Playfair Display (@fontsource, en frontmatter).
        Mantenemos el preconnect a Unsplash, que sí es un origen externo de imágenes. */}
    <link rel="preconnect" href="https://images.unsplash.com" />

    {heroPreload && <link rel="preload" as="image" href={heroPreload} fetchpriority="high" />}

    <style>
      .font-display {
        font-family: 'Playfair Display Variable', 'Playfair Display', Georgia, serif;
      }
    </style>
  </head>
  <body class="bg-amber-50/30 text-stone-900 antialiased">
    <slot />

    {isDemo && (
      <Fragment>
        <a href="/oferta-de-lanzamiento" class="demo-badge" data-back-to-offer>
          ← Volver a la oferta
        </a>
        <script is:inline>
          // Si la demo se abrió desde la oferta (pestaña con opener), cerrarla y
          // volver a esa pestaña. Si se llegó por enlace directo, navegar.
          document.querySelector('[data-back-to-offer]')?.addEventListener('click', (e) => {
            if (window.opener && !window.opener.closed) {
              e.preventDefault();
              try { window.opener.focus(); } catch (err) {}
              window.close();
            }
          });
        </script>
      </Fragment>
    )}

    <script>
      const observer = new IntersectionObserver(
        (entries, obs) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              obs.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.15 },
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
