---
import '@fontsource-variable/inter';
// URL hasheada del subset latino (el que realmente usamos) para precargarlo.
import interLatinUrl from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import '../styles/global.css';
import { getLangFromUrl, useTranslations, alternateLangPath, localizedPath } from '../i18n/utils';
import type { TranslationKey } from '../i18n/ui';
import PromoBanner from '../components/PromoBanner.astro';
import LangSuggestion from '../components/LangSuggestion.astro';

interface Props {
  titleKey: TranslationKey;
  descriptionKey: TranslationKey;
  pathWithoutLang: string;
  /** og:type — default 'website', usar 'article' o 'product' donde aplique */
  ogType?: string;
  /** Tipo schema.org de la página (WebPage, ContactPage, CollectionPage, AboutPage…) */
  pageType?: string;
  /** Si la página debe excluirse de buscadores */
  noindex?: boolean;
  /** Nodos JSON-LD extra (objeto o array) que se añaden al @graph de la página */
  jsonLd?: object | object[];
  /** Override de la imagen de vista previa. Si se omite, se usa la generada por URL. */
  ogImage?: string;
}

const {
  titleKey,
  descriptionKey,
  pathWithoutLang,
  ogType = 'website',
  pageType = 'WebPage',
  noindex = false,
  jsonLd,
  ogImage,
} = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const alt = alternateLangPath(lang, pathWithoutLang);
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const title = t(titleKey);
const description = t(descriptionKey);

// Imagen OG por URL: cada página tiene su propia tarjeta generada en build
// (/og/<slug>-<lang>.png). Se puede sobreescribir con la prop ogImage.
const OG_KEYS: Record<string, string> = {
  '/': 'home',
  '/contacto': 'contact',
  '/proyectos': 'projects',
  '/proyectos/hostalk': 'hostalk',
  '/privacidad': 'privacy',
  '/oferta-de-lanzamiento': 'offer',
};
const ogKey = OG_KEYS[pathWithoutLang];
const resolvedOgImage = ogImage ?? (ogKey ? `/og/${ogKey}-${lang}.png` : '/og-image.png');
const ogImageUrl = new URL(resolvedOgImage, Astro.site).toString();
const siteName = 'Ferser';
const ogLocale = lang === 'es' ? 'es_CO' : 'en_US';
const schemaLang = lang === 'es' ? 'es-CO' : 'en-US';

// ─── JSON-LD en @graph: cómo lo arman los sitios grandes ────────────────────
// Identificadores estables y enlazados entre nodos por @id.
const orgId = 'https://ferser.co/#organization';
const siteId = 'https://ferser.co/#website';
const pageId = `${canonical}#webpage`;
const breadcrumbId = `${canonical}#breadcrumb`;

const organization = {
  '@type': 'Organization',
  '@id': orgId,
  name: 'Ferser',
  url: 'https://ferser.co',
  logo: { '@type': 'ImageObject', url: 'https://ferser.co/favicon.svg' },
  image: 'https://ferser.co/og-image.png',
  description: 'Soluciones informáticas a la medida en Colombia.',
  sameAs: [
    'https://github.com/ferser-co',
    'https://www.linkedin.com/in/zebastian-fernandez-05705b168/',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'contacto@ferser.co',
    telephone: '+573052532602',
    contactType: 'customer service',
    areaServed: ['CO', 'ES', 'US'],
    availableLanguage: ['Spanish', 'English'],
  },
};

const website = {
  '@type': 'WebSite',
  '@id': siteId,
  url: 'https://ferser.co',
  name: 'Ferser',
  description: 'Soluciones informáticas a la medida en Colombia.',
  inLanguage: schemaLang,
  publisher: { '@id': orgId },
};

// Migas: Inicio → (sección) → página actual. Etiquetas localizadas.
const TRAILS: Record<string, { es: string; en: string; path: string }[]> = {
  '/': [],
  '/contacto': [{ es: 'Contacto', en: 'Contact', path: '/contacto' }],
  '/proyectos': [{ es: 'Proyectos', en: 'Projects', path: '/proyectos' }],
  '/proyectos/hostalk': [
    { es: 'Proyectos', en: 'Projects', path: '/proyectos' },
    { es: 'hosTalk', en: 'hosTalk', path: '/proyectos/hostalk' },
  ],
  '/privacidad': [{ es: 'Privacidad', en: 'Privacy', path: '/privacidad' }],
  '/oferta-de-lanzamiento': [
    { es: 'Oferta de lanzamiento', en: 'Launch offer', path: '/oferta-de-lanzamiento' },
  ],
};
const homeLabel = lang === 'es' ? 'Inicio' : 'Home';
const trail = TRAILS[pathWithoutLang] ?? [];
const crumbItems = [
  { name: homeLabel, url: new URL(localizedPath(lang, '/'), Astro.site).toString() },
  ...trail.map((c) => ({
    name: lang === 'es' ? c.es : c.en,
    url: new URL(localizedPath(lang, c.path), Astro.site).toString(),
  })),
];
const breadcrumb = {
  '@type': 'BreadcrumbList',
  '@id': breadcrumbId,
  itemListElement: crumbItems.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name,
    item: c.url,
  })),
};

const webpage = {
  '@type': pageType,
  '@id': pageId,
  url: canonical,
  name: title,
  description,
  inLanguage: schemaLang,
  isPartOf: { '@id': siteId },
  about: { '@id': orgId },
  primaryImageOfPage: { '@type': 'ImageObject', url: ogImageUrl },
  breadcrumb: { '@id': breadcrumbId },
};

const extra = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const ldData = {
  '@context': 'https://schema.org',
  '@graph': [organization, website, webpage, breadcrumb, ...extra],
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {/* Precarga del subset latino de Inter: baja en paralelo y temprano,
        acortando la cadena crítica y acelerando el LCP del texto. */}
    <link rel="preload" href={interLatinUrl} as="font" type="font/woff2" crossorigin="anonymous" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#020617" media="(prefers-color-scheme: dark)" />

    {/* Canonical + hreflang */}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={lang} href={canonical} />
    <link rel="alternate" hreflang={alt.lang} href={new URL(alt.href, Astro.site).toString()} />
    <link rel="alternate" hreflang="x-default" href={new URL(pathWithoutLang === '/' ? '/' : pathWithoutLang, Astro.site).toString()} />

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_CO'} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />

    {/* Fuente Inter servida en local vía @fontsource-variable/inter
        (importada en el frontmatter). Sin peticiones a fonts.googleapis.com. */}

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {/* JSON-LD */}
    <script type="application/ld+json" set:html={JSON.stringify(ldData)} is:inline />

    <script is:inline>
      // No-flash dark-mode + currency init: corre antes del primer paint.
      // Detección puramente GEOGRÁFICA (independiente del idioma de la página).
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const prefers = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const dark = stored === 'dark' || (!stored && prefers);
          document.documentElement.classList.toggle('dark', dark);
        } catch (_) {}

        try {
          const override = localStorage.getItem('currency');
          let currency = override;
          if (!currency) {
            // Sincrónico por timezone — best-effort sin requests externos.
            // El upgrade async por IP corrige si la TZ no coincide con la región real.
            const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
            if (tz === 'America/Bogota') {
              currency = 'COP';
            } else if (/^(Europe|Africa|Atlantic)\//.test(tz)) {
              currency = 'EUR';
            } else {
              currency = 'USD';
            }
          }
          document.documentElement.setAttribute('data-currency', currency);
        } catch (_) {
          document.documentElement.setAttribute('data-currency', 'USD');
        }
      })();
    </script>
  </head>
  <body class="bg-gradient-to-br from-slate-50 via-blue-50 to-cyan-50 text-slate-900 antialiased overflow-x-hidden dark:from-slate-950 dark:via-slate-900 dark:to-slate-950 dark:text-slate-100 transition-colors">
    <PromoBanner />
    <slot />
    <LangSuggestion pathWithoutLang={pathWithoutLang} />

    {/* JS no crítico (bundleado y diferido por Astro): interacciones de UI y
        personalización por región. Ambos corren tras el parse, sin bloquear. */}
    <script>
      import '../scripts/ui';
      import '../scripts/geo';
    </script>
  </body>
</html>
