---
import '../styles/global.css';
import { getLangFromUrl, useTranslations, alternateLangPath } from '../i18n/utils';
import type { TranslationKey } from '../i18n/ui';
import PromoBanner from '../components/PromoBanner.astro';

interface Props {
  titleKey: TranslationKey;
  descriptionKey: TranslationKey;
  pathWithoutLang: string;
  /** og:type — default 'website', usar 'article' o 'product' donde aplique */
  ogType?: string;
  /** Si la página debe excluirse de buscadores */
  noindex?: boolean;
  /** JSON-LD adicional inyectado en <head> */
  jsonLd?: object;
  /** Imagen para la vista previa al compartir (PNG/JPG). Default: /og-image.png */
  ogImage?: string;
}

const { titleKey, descriptionKey, pathWithoutLang, ogType = 'website', noindex = false, jsonLd, ogImage = '/og-image.png' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const alt = alternateLangPath(lang, pathWithoutLang);
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const title = t(titleKey);
const description = t(descriptionKey);
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const siteName = 'Ferser';

// JSON-LD Organization por defecto (sobreescribible por la prop jsonLd)
const defaultLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Ferser',
  url: 'https://ferser.co',
  logo: 'https://ferser.co/favicon.svg',
  description: 'Ingeniería de software a la medida en Colombia.',
  sameAs: [
    'https://github.com/ferser-co',
    'https://www.linkedin.com/in/zebastian-fernandez-05705b168/',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'contacto@ferser.co',
    contactType: 'customer service',
    availableLanguage: ['Spanish', 'English'],
  },
};
const ldData = jsonLd ?? defaultLd;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#020617" media="(prefers-color-scheme: dark)" />

    {/* Canonical + hreflang */}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={lang} href={canonical} />
    <link rel="alternate" hreflang={alt.lang} href={new URL(alt.href, Astro.site).toString()} />
    <link rel="alternate" hreflang="x-default" href={new URL(pathWithoutLang === '/' ? '/' : pathWithoutLang, Astro.site).toString()} />

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={lang === 'es' ? 'es_CO' : 'en_US'} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />

    {/* Fuentes — preconnect acelera la primera conexión TLS */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {/* JSON-LD */}
    <script type="application/ld+json" set:html={JSON.stringify(ldData)} is:inline />

    <script is:inline>
      // No-flash dark-mode + currency init: corre antes del primer paint.
      // Detección puramente GEOGRÁFICA (independiente del idioma de la página).
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const prefers = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const dark = stored === 'dark' || (!stored && prefers);
          document.documentElement.classList.toggle('dark', dark);
        } catch (_) {}

        try {
          const override = localStorage.getItem('currency');
          let currency = override;
          if (!currency) {
            // Sincrónico por timezone — best-effort sin requests externos.
            // El upgrade async por IP corrige si la TZ no coincide con la región real.
            const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
            if (tz === 'America/Bogota') {
              currency = 'COP';
            } else if (/^(Europe|Africa|Atlantic)\//.test(tz)) {
              currency = 'EUR';
            } else {
              currency = 'USD';
            }
          }
          document.documentElement.setAttribute('data-currency', currency);
        } catch (_) {
          document.documentElement.setAttribute('data-currency', 'USD');
        }
      })();
    </script>
  </head>
  <body class="bg-gradient-to-br from-slate-50 via-blue-50 to-cyan-50 text-slate-900 antialiased overflow-x-hidden dark:from-slate-950 dark:via-slate-900 dark:to-slate-950 dark:text-slate-100 transition-colors">
    <PromoBanner />
    <slot />

    <script>
      const observer = new IntersectionObserver(
        (entries, obs) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              obs.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.1 },
      );
      document.querySelectorAll('.fade-in-up').forEach((el) => observer.observe(el));

      // Theme toggle (delegado, soporta múltiples botones)
      function applyTheme(dark) {
        document.documentElement.classList.toggle('dark', dark);
        localStorage.setItem('theme', dark ? 'dark' : 'light');
      }

      // Currency dropdown: abrir/cerrar menú + seleccionar opción
      function setCurrency(c) {
        document.documentElement.setAttribute('data-currency', c);
        localStorage.setItem('currency', c);
        closeCurrencyMenus();
      }
      function closeCurrencyMenus() {
        document.querySelectorAll('[data-currency-menu]').forEach((m) => m.classList.add('hidden'));
        document.querySelectorAll('[data-currency-trigger]').forEach((b) => b.setAttribute('aria-expanded', 'false'));
      }
      function toggleCurrencyMenu(trigger) {
        const dropdown = trigger.closest('[data-currency-dropdown]');
        const menu = dropdown?.querySelector('[data-currency-menu]');
        const isOpen = !menu.classList.contains('hidden');
        closeCurrencyMenus();
        if (!isOpen) {
          menu.classList.remove('hidden');
          trigger.setAttribute('aria-expanded', 'true');
        }
      }

      document.addEventListener('click', (e) => {
        if (e.target.closest('[data-theme-toggle]')) {
          const isDark = document.documentElement.classList.contains('dark');
          applyTheme(!isDark);
          return;
        }
        const trigger = e.target.closest('[data-currency-trigger]');
        if (trigger) {
          e.stopPropagation();
          toggleCurrencyMenu(trigger);
          return;
        }
        const pick = e.target.closest('[data-currency-pick]');
        if (pick) {
          e.stopPropagation();
          setCurrency(pick.getAttribute('data-currency-pick'));
          return;
        }
        // Click fuera → cerrar
        if (!e.target.closest('[data-currency-dropdown]')) {
          closeCurrencyMenus();
        }
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeCurrencyMenus();
      });

      // Upgrade async por IP — corrige cuando la TZ del navegador no coincide
      // con la región real (caso típico: VPN, navegador con TZ no actualizada).
      // No corre si el usuario ya eligió explícitamente.
      (async function () {
        if (localStorage.getItem('currency')) return;
        const html = document.documentElement;
        const current = html.getAttribute('data-currency');
        try {
          const controller = new AbortController();
          const timer = setTimeout(() => controller.abort(), 3000);
          const r = await fetch('https://ipapi.co/json/', { signal: controller.signal });
          clearTimeout(timer);
          if (!r.ok) return;
          const d = await r.json();
          const EUR_COUNTRIES = new Set([
            // Eurozona
            'AT','BE','CY','DE','EE','ES','FI','FR','GR','HR','IE','IT','LT','LU','LV','MT','NL','PT','SI','SK',
            // Europa cercana (preferimos EUR sobre USD)
            'GB','CH','NO','SE','DK','IS','LI','MC','SM','VA','AD',
          ]);
          let next;
          if (d.country_code === 'CO') next = 'COP';
          else if (EUR_COUNTRIES.has(d.country_code)) next = 'EUR';
          else next = 'USD';
          if (next !== current) html.setAttribute('data-currency', next);
        } catch (_) {}
      })();
    </script>
  </body>
</html>
